---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  runningHead?: string;
  page?: string;
  theme?: 'light' | 'dark';
}

const {
  title = 'State of AI Code Review (2026)',
  description = 'A field report on AI code review at scale. 162,262 AI suggestions delivered to 464 engineering organizations between September 2025 and May 2026. 32% became code.',
  runningHead = 'State of AI Code Review',
  page = 'Frontispiece',
  theme = 'light',
} = Astro.props;

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};

const navItems = [
  { num: '01', label: 'Bugs',            href: '/bugs/' },
  { num: '02', label: 'Vulnerabilities', href: '/vulnerabilities/' },
  { num: '03', label: 'Rules',           href: '/rules/' },
  { num: '04', label: 'Models',          href: '/models/' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Albert+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={['font-sans', theme === 'dark' ? 'theme-dark' : 'bg-paper-100 text-ink-900']}>

    <div class="scroll-progress" id="scroll-progress"></div>

    <!-- ─── HEADER · sticky · backdrop-blurred · active-aware ─── -->
    <header class="site-header sticky top-0 z-50">
      <div class="max-w-[1440px] mx-auto px-5 md:px-10 lg:px-14">

        <!-- Top row: logo + desktop nav + mobile toggle -->
        <div class="flex items-center justify-between gap-4 py-3.5 md:py-4">

          <!-- Logo -->
          <a href="/" class="group flex items-center gap-3 leading-none shrink-0">
            <span class="relative flex items-center justify-center w-2 h-2">
              <span class="absolute inline-flex h-full w-full rounded-full opacity-75 cursor-blink" style="background: var(--color-phosphor-500);"></span>
              <span class="relative inline-flex rounded-full w-2 h-2" style="background: var(--color-phosphor-500);"></span>
            </span>
            <div class="site-logo font-display text-[17px] md:text-[19px] leading-none">
              <span class="italic">State of AI</span> Code Review
            </div>
          </a>

          <!-- Desktop nav -->
          <nav class="hidden md:flex items-center gap-px" aria-label="Chapters">
            {navItems.map((c) => {
              const active = isActive(c.href);
              return (
                <a
                  href={c.href}
                  aria-current={active ? 'page' : undefined}
                  class:list={['nav-link group relative px-3.5 py-2.5 font-mono text-[11px] tracking-[0.2em] uppercase font-medium transition-colors', active ? 'is-active' : '']}
                >
                  <span class="text-mist-600 mr-1.5">§ {c.num}</span>
                  <span class="text-mist-400 group-hover:text-mist-50 transition-colors">{c.label}</span>
                  {active && <span class="active-underline"></span>}
                </a>
              );
            })}
            <span class="text-mist-600 mx-1.5">/</span>
            <a
              href="/methodology/"
              aria-current={isActive('/methodology/') ? 'page' : undefined}
              class:list={['nav-link relative px-3.5 py-2.5 font-mono text-[11px] tracking-[0.2em] uppercase font-medium transition-colors', isActive('/methodology/') ? 'is-active' : '']}
            >
              <span class="text-mist-400 hover:text-mist-50">Methodology</span>
              {isActive('/methodology/') && <span class="active-underline"></span>}
            </a>
          </nav>

          <!-- Mobile toggle -->
          <button
            class="md:hidden flex items-center gap-2 font-mono text-[11px] tracking-[0.2em] uppercase text-mist-200 px-3 py-2 border border-night-50"
            aria-label="Open chapters"
            aria-expanded="false"
            data-mobile-toggle
          >
            <span data-toggle-icon>≡</span>
            <span>Index</span>
          </button>
        </div>

        <!-- Mobile nav drawer -->
        <nav class="md:hidden border-t border-night-50 py-3 hidden" data-mobile-nav aria-label="Chapters (mobile)">
          <div class="space-y-px">
            {navItems.map((c) => {
              const active = isActive(c.href);
              return (
                <a
                  href={c.href}
                  class:list={['flex items-baseline gap-3 py-2.5 px-2 font-mono text-[12px] tracking-[0.18em] uppercase', active ? 'text-phosphor-500' : 'text-mist-200 hover:text-mist-50']}
                >
                  <span class="text-mist-600 w-8">§ {c.num}</span>
                  <span>{c.label}</span>
                  {active && <span class="ml-auto text-phosphor-500">●</span>}
                </a>
              );
            })}
            <a
              href="/methodology/"
              class:list={['flex items-baseline gap-3 py-2.5 px-2 font-mono text-[12px] tracking-[0.18em] uppercase', isActive('/methodology/') ? 'text-phosphor-500' : 'text-mist-400 hover:text-mist-50']}
            >
              <span class="text-mist-600 w-8">/</span>
              <span>Methodology</span>
              {isActive('/methodology/') && <span class="ml-auto text-phosphor-500">●</span>}
            </a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- ─── FOOTER ─── -->
    <footer class="border-t border-night-50 bg-night-200">
      <div class="max-w-[1440px] mx-auto px-5 md:px-10 lg:px-14 py-10 md:py-12">
        <div class="grid grid-cols-12 gap-8 items-baseline">

          <div class="col-span-12 md:col-span-6">
            <a href="/" class="group inline-flex items-center gap-3 leading-none">
              <span class="inline-block w-2 h-2 rounded-full" style="background: var(--color-phosphor-500);"></span>
              <span class="font-display text-mist-50 text-[19px]"><span class="italic">State of AI</span> Code Review</span>
            </a>
            <p class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-mist-400 mt-3">
              Snapshot 2026-Q2 · Research by <a href="https://kodus.io" class="text-mist-200 hover:text-phosphor-500 transition-colors">Kodus</a>
            </p>
          </div>

          <div class="col-span-12 md:col-span-6 md:text-right">
            <div class="font-mono text-[12px] text-mist-50 bg-night-300 border-l-2 border-phosphor-500 inline-block text-left p-3 leading-relaxed">
              State of AI Code Review (2026-Q2).<br/>
              https://stateofcodereview.com
            </div>
            <div class="mt-4 flex gap-5 flex-wrap md:justify-end font-mono text-[10.5px] tracking-[0.22em] uppercase">
              <a href="/methodology/" class="text-mist-200 hover:text-phosphor-500">↳ Methodology</a>
              <a href="https://github.com/kodustech/stateofcodereview.com" class="text-mist-200 hover:text-phosphor-500">↳ GitHub</a>
              <a href="https://creativecommons.org/licenses/by/4.0/" class="text-mist-200 hover:text-phosphor-500">↳ CC BY 4.0</a>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Scroll progress
      const progress = document.getElementById('scroll-progress');
      function updateProgress() {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        const pct = max > 0 ? (h.scrollTop || document.body.scrollTop) / max : 0;
        if (progress) progress.style.setProperty('--scroll', String(pct));
      }
      document.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();

      // Mobile nav toggle
      const toggle = document.querySelector('[data-mobile-toggle]');
      const mobileNav = document.querySelector('[data-mobile-nav]');
      const toggleIcon = document.querySelector('[data-toggle-icon]');
      if (toggle && mobileNav) {
        toggle.addEventListener('click', () => {
          const isHidden = mobileNav.classList.contains('hidden');
          mobileNav.classList.toggle('hidden');
          toggle.setAttribute('aria-expanded', String(isHidden));
          if (toggleIcon) toggleIcon.textContent = isHidden ? '×' : '≡';
        });
      }

      // Header background opacity on scroll
      const header = document.querySelector('.site-header');
      if (header) {
        function updateHeader() {
          if (window.scrollY > 24) header.classList.add('scrolled');
          else header.classList.remove('scrolled');
        }
        document.addEventListener('scroll', updateHeader, { passive: true });
        updateHeader();
      }
    </script>
  </body>
</html>
