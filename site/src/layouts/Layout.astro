---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  runningHead?: string;
  page?: string;
  theme?: 'light' | 'dark';
}

const {
  title = 'State of AI Code Review (2026)',
  description = 'A field report on AI code review at scale. 112,336 AI suggestions delivered to 456 engineering organizations between September 2025 and May 2026. 17% became code. 67% were ignored.',
  runningHead = 'State of AI Code Review',
  page = 'Frontispiece',
  theme = 'light',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Albert+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={['font-sans', theme === 'dark' ? 'theme-dark' : 'bg-paper-100 text-ink-900']}>

    <div class="scroll-progress" id="scroll-progress"></div>

    <header class="border-b-2 border-ink-900">
      <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-6 flex items-end justify-between gap-6 flex-wrap">
        <a href="/" class="block leading-none">
          <span class="font-display italic text-3xl md:text-[2.4rem] text-ink-900">State of AI</span>
          <span class="font-display text-3xl md:text-[2.4rem] text-ink-900"> Code Review</span>
        </a>
        <nav class="flex gap-2 md:gap-1 flex-wrap items-center">
          <a href="/bugs/"             class="tracked text-ink-700 hover:text-paper-50 hover:bg-ink-900 px-3 py-2 transition-colors">§ 01 Bugs</a>
          <a href="/vulnerabilities/"  class="tracked text-ink-700 hover:text-paper-50 hover:bg-ink-900 px-3 py-2 transition-colors">§ 02 Vulnerabilities</a>
          <a href="/rules/"            class="tracked text-ink-700 hover:text-paper-50 hover:bg-ink-900 px-3 py-2 transition-colors">§ 03 Rules</a>
          <a href="/models/"           class="tracked text-ink-700 hover:text-paper-50 hover:bg-ink-900 px-3 py-2 transition-colors">§ 04 Models</a>
          <span class="text-ink-300 hidden md:inline">·</span>
          <a href="/methodology/"      class="tracked text-ink-500 hover:text-oxblood-500 px-3 py-2 transition-colors">Methodology</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-ink-900/30 bg-paper-50">
      <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-8 flex flex-wrap items-center justify-between gap-x-8 gap-y-3 text-[13px] text-ink-500">
        <div>
          Research by <a class="text-ink-900 underline decoration-1 underline-offset-4 hover:text-oxblood-500" href="https://kodus.io">Kodus</a>
          <span class="text-ink-300 mx-2">·</span>
          <a href="https://creativecommons.org/licenses/by/4.0/" class="hover:text-oxblood-500">CC BY 4.0</a>
          <span class="text-ink-300 mx-2">·</span>
          <a href="https://github.com/kodustech/stateofcodereview.com" class="hover:text-oxblood-500">GitHub</a>
        </div>
        <div class="font-mono text-[11px]">
          State of AI Code Review (2026-Q2). stateofcodereview.com
        </div>
      </div>
    </footer>

    <script is:inline>
      const progress = document.getElementById('scroll-progress');
      function updateProgress() {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        const pct = max > 0 ? (h.scrollTop || document.body.scrollTop) / max : 0;
        if (progress) progress.style.setProperty('--scroll', String(pct));
      }
      document.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    </script>
  </body>
</html>
