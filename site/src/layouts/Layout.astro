---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  runningHead?: string;
  page?: string;
}

const {
  title = 'State of AI Code Review (2026)',
  description = 'A field report on AI code review at scale. 17,773 AI suggestions across 200 engineering organizations and 103 programming languages.',
  runningHead = 'State of AI Code Review',
  page = 'Frontispiece',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Albert+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-paper-100 text-ink-900 font-sans">

    <div class="scroll-progress" id="scroll-progress"></div>

    <!-- Spine bar -->
    <div class="border-b border-ink-900/80 bg-paper-100">
      <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-2 flex items-center justify-between gap-6">
        <div class="tracked-xs text-ink-700 flex items-center gap-2">
          <span class="inline-block w-2 h-2 rounded-full bg-oxblood-500"></span>
          <span>Vol. I</span>
          <span class="text-ink-300">·</span>
          <span>{runningHead}</span>
          <span class="text-ink-300">·</span>
          <span>Snapshot 2026-Q2</span>
        </div>
        <div class="tracked-xs text-ink-500 hidden md:flex items-center gap-2">
          <span>By</span>
          <a href="https://kodus.io" class="text-ink-900 hover:text-oxblood-500">Kodus</a>
          <span class="text-ink-300">·</span>
          <a href="https://github.com/kodustech/stateofcodereview.com" class="hover:text-oxblood-500">GitHub</a>
        </div>
      </div>
    </div>

    <!-- Masthead -->
    <header class="border-b-2 border-ink-900">
      <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-6 flex items-end justify-between gap-6 flex-wrap">
        <a href="/" class="block leading-none">
          <span class="font-display italic text-3xl md:text-[2.4rem] text-ink-900">State of AI</span>
          <span class="font-display text-3xl md:text-[2.4rem] text-ink-900"> Code Review</span>
        </a>
        <nav class="flex gap-3 md:gap-2 flex-wrap items-center">
          <a href="/bugs/"             class="tracked text-ink-700 hover:text-paper-50 hover:bg-ink-900 px-3 py-2 transition-colors">§ 01 Bugs</a>
          <a href="/vulnerabilities/"  class="tracked text-ink-700 hover:text-paper-50 hover:bg-ink-900 px-3 py-2 transition-colors">§ 02 Vulnerabilities</a>
          <a href="/cross-file/"       class="tracked text-ink-700 hover:text-paper-50 hover:bg-ink-900 px-3 py-2 transition-colors">§ 03 Cross-file</a>
          <a href="/rules/"            class="tracked text-ink-700 hover:text-paper-50 hover:bg-ink-900 px-3 py-2 transition-colors">§ 04 Rules</a>
          <span class="text-ink-300 hidden md:inline">·</span>
          <a href="/methodology/"      class="tracked text-ink-500 hover:text-oxblood-500 px-3 py-2 transition-colors">Methodology</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Colophon footer -->
    <footer class="border-t-2 border-ink-900 bg-paper-50">
      <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-16">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
          <div class="md:col-span-5">
            <div class="tracked text-ink-500 mb-4">Colophon</div>
            <p class="font-display italic text-3xl leading-tight text-ink-900">
              State of AI Code Review.<br/>A field report by <a class="underline decoration-1 underline-offset-[6px] hover:text-oxblood-500" href="https://kodus.io">Kodus</a>.
            </p>
            <p class="text-ink-500 mt-6 leading-relaxed max-w-md">
              Set in <span class="font-display italic">Instrument Serif</span>, Albert Sans, and JetBrains Mono. Cream <span class="font-mono text-xs bg-paper-200 px-1.5">#f4eee0</span> · ink <span class="font-mono text-xs bg-paper-200 px-1.5">#1a1715</span> · oxblood <span class="font-mono text-xs bg-paper-200 px-1.5">#8b1e1e</span>.
            </p>
          </div>

          <div class="md:col-span-3">
            <div class="tracked text-ink-500 mb-4">License</div>
            <p class="text-ink-700 leading-relaxed">
              Report and data licensed under <a href="https://creativecommons.org/licenses/by/4.0/" class="underline decoration-1 underline-offset-4 hover:text-oxblood-500">CC BY 4.0</a>. Reuse with attribution.
            </p>
          </div>

          <div class="md:col-span-4">
            <div class="tracked text-ink-500 mb-4">Recommended citation</div>
            <div class="font-mono text-[12px] leading-relaxed text-ink-700 bg-paper-200 border-l-2 border-oxblood-500 p-4">
              State of AI Code Review (2026-Q2).<br/>
              Research by Kodus.<br/>
              https://stateofcodereview.com
            </div>
            <a href="https://github.com/kodustech/stateofcodereview.com" class="tracked text-ink-500 hover:text-oxblood-500 mt-5 inline-block">↳ Repository on GitHub</a>
          </div>
        </div>

        <div class="double-rule mt-16 flex justify-between items-baseline text-ink-900">
          <div class="tracked-xs text-ink-500">Kodustech · MMXXVI</div>
          <div class="tracked-xs text-ink-500">{page}</div>
        </div>
      </div>
    </footer>

    <script is:inline>
      const progress = document.getElementById('scroll-progress');
      function updateProgress() {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        const pct = max > 0 ? (h.scrollTop || document.body.scrollTop) / max : 0;
        if (progress) progress.style.setProperty('--scroll', String(pct));
      }
      document.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    </script>
  </body>
</html>
