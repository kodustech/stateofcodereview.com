---
import Layout from '../layouts/Layout.astro';

const topRules = [
  { rank: 1,  title: 'Write a clear, scoped PR title',                       orgs: 45, cat: 'process' },
  { rank: 2,  title: 'Always sanitize user inputs',                          orgs: 36, cat: 'security' },
  { rank: 3,  title: 'Prohibit hardcoded secrets',                           orgs: 30, cat: 'security' },
  { rank: 4,  title: 'Avoid using eval',                                     orgs: 29, cat: 'security' },
  { rank: 5,  title: 'Always validate JSON parsing',                         orgs: 27, cat: 'reliability' },
  { rank: 6,  title: 'Avoid equality operators in loop termination',         orgs: 27, cat: 'correctness' },
  { rank: 7,  title: 'Prevent SQL injection in queries',                     orgs: 25, cat: 'security' },
  { rank: 8,  title: 'Enforce TypeScript strict mode',                       orgs: 25, cat: 'types' },
  { rank: 9,  title: 'Mark unchanged variables as const',                    orgs: 24, cat: 'correctness' },
  { rank: 10, title: 'Avoid asynchronous operations in constructors',        orgs: 24, cat: 'correctness' },
  { rank: 11, title: 'Prevent hardcoded secrets',                            orgs: 24, cat: 'security' },
  { rank: 12, title: 'Ensure React list keys are stable between renders',    orgs: 22, cat: 'framework' },
  { rank: 13, title: 'Enforce strict TypeScript configuration',              orgs: 22, cat: 'types' },
  { rank: 14, title: 'Do not nest React components',                         orgs: 21, cat: 'framework' },
  { rank: 15, title: 'Do not export mutable variables',                      orgs: 20, cat: 'correctness' },
  { rank: 16, title: 'Do not ignore exceptions',                             orgs: 19, cat: 'reliability' },
  { rank: 17, title: 'Avoid building system commands from user input',       orgs: 18, cat: 'security' },
  { rank: 18, title: 'React children should not be passed as props',         orgs: 18, cat: 'framework' },
  { rank: 19, title: 'Prevent open redirect vulnerabilities in DOM updates', orgs: 17, cat: 'security' },
  { rank: 20, title: 'Prevent SQL injection via string concatenation',       orgs: 16, cat: 'security' },
];

const catTone: Record<string, string> = {
  security:    'var(--color-phosphor-500)',
  correctness: 'var(--color-phosphor-300)',
  reliability: 'var(--color-signal-cyan)',
  types:       'oklch(72% 0.13 200)',
  framework:   'oklch(72% 0.08 280)',
  process:     'var(--color-mist-400)',
};

const maxOrgs = Math.max(...topRules.map((r) => r.orgs));

const catCounts = topRules.reduce<Record<string, number>>((acc, r) => {
  acc[r.cat] = (acc[r.cat] || 0) + 1;
  return acc;
}, {});
---

<Layout
  title="What 610 engineering teams codified · State of AI Code Review"
  description="7,276 codified review rules from 610 organizations. 60,918 kody_rules suggestions delivered with 29.8% implementation rate. The top 20 rules adopted across distinct teams."
  runningHead="§ 03 Rules"
  page="Plate III"
  theme="dark"
>

  <!-- HERO -->
  <section class="border-b border-night-50 bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-16">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-9">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-5 reveal reveal-1">
            ◆ Chapter § 03 · Rules
          </div>
          <h1 class="font-display leading-[0.95] tracking-tight text-mist-50 reveal reveal-2" style="font-size: clamp(2.5rem, 6.5vw, 5.5rem);">
            What 610 engineering teams<br/><span class="italic phosphor">codified.</span>
          </h1>
        </div>
        <aside class="col-span-12 md:col-span-3 md:pt-4 reveal reveal-3">
          <div class="border border-night-50 bg-night-200 p-5">
            <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-4">At a glance</div>
            <ul class="space-y-3 text-mist-50">
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2"><span class="text-[13px] text-mist-200">Total rules</span><span class="font-mono text-[13px]">7,276</span></li>
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2"><span class="text-[13px] text-mist-200">Organizations</span><span class="font-mono text-[13px]">610</span></li>
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2"><span class="text-[13px] text-mist-200">Median per org</span><span class="font-mono text-[13px]">11.9</span></li>
              <li class="flex items-baseline justify-between"><span class="text-[13px] text-mist-200">Largest library</span><span class="font-mono text-[13px]">328</span></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- IMPLEMENTATION RATE FOR KODY_RULES -->
  <section class="border-b border-night-50 bg-night-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20 md:py-24">
      <div class="grid grid-cols-12 gap-10 items-center">
        <div class="col-span-12 md:col-span-7">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-5">
            ◆ When teams write rules, devs follow them
          </div>
          <h2 class="font-display tracking-tight leading-[0.95] text-mist-50" style="font-size: clamp(2.25rem, 5.5vw, 4.5rem);">
            <span class="italic phosphor">30%</span> of rule-driven<br/>findings earn a fix.
          </h2>
          <p class="text-mist-200 leading-[1.65] text-[16px] mt-8 max-w-xl">
            60,918 suggestions were generated from team-authored rules. 30% of them resulted in a change on the flagged lines. Roughly on par with bug findings (33%) — meaning custom rules behave like first-class signal, not aspirational documentation.
          </p>
        </div>
        <div class="col-span-12 md:col-span-5">
          <div class="font-display phosphor leading-none" style="font-size: clamp(5rem, 14vw, 11rem);">29.8%</div>
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mt-3">Implementation rate</div>

          <div class="mt-8 space-y-3">
            <div>
              <div class="flex items-baseline justify-between mb-1">
                <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-200">Delivered</span>
                <span class="font-mono text-mist-50 text-sm">60,918</span>
              </div>
            </div>
            <div>
              <div class="flex items-baseline justify-between mb-1">
                <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-200">Organizations</span>
                <span class="font-mono text-mist-50 text-sm">175</span>
              </div>
            </div>
            <div>
              <div class="flex items-baseline justify-between mb-1">
                <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-200">Applied exactly</span>
                <span class="font-mono text-mist-50 text-sm">13.7% (8,365)</span>
              </div>
            </div>
            <div>
              <div class="flex items-baseline justify-between mb-1">
                <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-200">Adapted to fit</span>
                <span class="font-mono text-mist-50 text-sm">16.0% (9,762)</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LEGEND -->
  <section class="border-b border-night-50 bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-4 flex flex-wrap items-center gap-4 font-mono text-[11px] text-mist-200">
      <span class="font-medium tracking-[0.22em] uppercase">Categories</span>
      {Object.entries(catCounts).map(([k, v]) => (
        <span class="flex items-center gap-2">
          <span class="inline-block w-3 h-3" style={`background: ${catTone[k]};`}></span>
          <span class="capitalize text-mist-50">{k}</span>
          <span class="text-mist-400">{v}</span>
        </span>
      ))}
      <span class="ml-auto text-mist-400">Bar · orgs adopting the rule</span>
    </div>
  </section>

  <!-- RULES LIST -->
  <section class="bg-night-100 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-16">
      <div class="flex items-baseline justify-between border-b border-night-50 pb-3 mb-2 flex-wrap gap-2">
        <h2 class="font-display italic text-mist-50" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">The Common List.</h2>
        <span class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-200">Top 20 by distinct organization count</span>
      </div>

      <div>
        {topRules.map((r) => {
          const pct = (r.orgs / maxOrgs) * 100;
          const tone = catTone[r.cat];
          return (
            <div class="grid grid-cols-12 gap-3 md:gap-4 items-center py-3.5 border-b border-night-50 group hover:bg-night-200/40 transition-colors">
              <div class="col-span-1 font-mono text-[12px] text-mist-400">{String(r.rank).padStart(2, '0')}</div>
              <div class="col-span-11 md:col-span-5 font-display text-mist-50 text-[16px] md:text-[18px] leading-snug group-hover:text-phosphor-500 transition-colors">{r.title}</div>
              <div class="col-span-7 md:col-span-4">
                <div class="h-[6px] bg-night-50 relative">
                  <div class="absolute inset-y-0 left-0 bar-grow" style={`background: ${tone}; width: ${pct}%; animation-delay: ${0.05 + r.rank * 0.02}s;`}></div>
                </div>
              </div>
              <div class="col-span-3 md:col-span-1 text-right">
                <span class="font-mono text-[10px] tracking-[0.18em] uppercase capitalize px-2 py-1" style={`background: ${tone}; color: var(--color-night-200);`}>{r.cat}</span>
              </div>
              <div class="col-span-2 md:col-span-1 text-right font-mono text-sm text-mist-50">
                {r.orgs}<span class="text-mist-400"> orgs</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CLOSER -->
  <section class="bg-night-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-3">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500">What this measures</div>
        </div>
        <div class="col-span-12 md:col-span-9">
          <p class="font-display italic text-mist-50 leading-[1.35]" style="font-size: clamp(1.5rem, 2.4vw, 2.25rem);">
            Each row is a rule title that appears verbatim or near-verbatim in at least three distinct organizations. Counts represent distinct organizations, not total rule instances. A team that copies the same rule twice still counts once.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
