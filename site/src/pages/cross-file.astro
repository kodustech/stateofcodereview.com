---
import Layout from '../layouts/Layout.astro';

const classes = [
  { n: '01', title: 'Business logic duplicated across files',  linterSees: 'Two functions, each locally correct.',                     aiSees: 'The same calculation implemented twice with subtle drift.',                  sample: 'logica de negocio para definir que etapas de candidatos componen una metrica esta duplicada. en calculate-candidate-metrics index.ts se utiliza para sumar los totales mientras que en dashboard-analytics-dto.ts la misma logica' },
  { n: '02', title: 'Inconsistent handling of the same concept', linterSees: 'Each handler is syntactically valid.',                     aiSees: 'One throws, one returns null. Consumers cannot rely on either.',              sample: 'address schema() throws a badmethodcallexception which fails loudly. boleto schema() returns a null pattern that fails silently. inconsistent strategies make consumer behavior unpredictable' },
  { n: '03', title: 'Schema or config drift across modules',     linterSees: 'Each version string is a valid string.',                   aiSees: 'Library versions disagree across files. Bug surface in the seam.',           sample: 'as versoes do jaspersoft studio e jasperreports library estao inconsistentes entre os arquivos. o arquivo .jrxml menciona a versao 6.5.1 enquanto o .jasper menciona a versao 6.5.0' },
  { n: '04', title: 'Type incompatibility across packages',      linterSees: 'Each function signature compiles.',                        aiSees: 'Interface returns concrete subtypes from a sibling package.',                sample: 'type incompatibility between go.lumeweb.com queryutil and go.lumeweb.com queryutil filter packages. the dnsrecordparser returns concrete types from the filter subpackage but the dnsservice interface methods expect base types' },
  { n: '05', title: 'N+1 split between controller and view',     linterSees: 'Controller eager-loads correctly. View scope is valid.',   aiSees: 'View bypasses the eager-load. The optimization is undone.',                  sample: 'consulta n+1 nao intencional. o controller pre-carrega a associacao historico_reajustes_ipca para evitar consultas extras. no entanto a view usa o escopo que dispara novas queries' },
  { n: '06', title: 'Test and code drift',                       linterSees: 'All tests pass against the old signature.',                aiSees: 'Function was refactored. Tests still assert the deprecated behavior.',       sample: 'backward-compatibility regression for analysis-results plot files. exportbutton.tsx and useoptimizationtabdata.ts now call downloadplotfile without legacy fallback so runs stored with the older naming will fail to export' },
];
---

<Layout
  title="What AI catches that linters cannot · State of AI Code Review"
  description="1,852 cross-file findings from production pull requests. Logic duplicated across files, schema drift, type incompatibility between packages, N+1 queries split between controller and view."
  runningHead="§ 03 Cross-file"
  page="Plate III"
>

  <!-- HERO -->
  <section class="border-b-2 border-ink-900">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-16 md:pt-20 pb-16">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-9">
          <h1 class="font-display leading-[0.95] tracking-tight text-ink-900 reveal reveal-1" style="font-size: clamp(2.5rem, 6.5vw, 5.5rem);">
            What AI catches<br/>that <span class="italic">linters cannot.</span>
          </h1>
        </div>
        <aside class="col-span-12 md:col-span-3 md:pt-6 reveal reveal-2">
          <div class="border-2 border-ink-900 bg-paper-200 p-5">
            <div class="tracked text-oxblood-500 mb-3">At a glance</div>
            <ul class="space-y-2 text-ink-900">
              <li class="flex items-baseline justify-between border-b border-paper-400/60 pb-1">
                <span class="text-sm">Cross-file findings</span>
                <span class="font-mono text-sm">1,852</span>
              </li>
              <li class="flex items-baseline justify-between border-b border-paper-400/60 pb-1">
                <span class="text-sm">Acceptance rate</span>
                <span class="font-mono text-sm text-moss-700">~94%</span>
              </li>
              <li class="flex items-baseline justify-between">
                <span class="text-sm">Categories</span>
                <span class="font-mono text-sm">6</span>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- VS HEADLINE -->
  <section class="dark-section border-b-2 border-ink-900">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <div class="grid grid-cols-12 gap-8 items-center">
        <div class="col-span-12 md:col-span-6 md:border-r md:border-paper-100/20 md:pr-10">
          <div class="tracked text-paper-300 mb-3">A linter sees</div>
          <p class="font-display italic text-paper-100 leading-[1.15]" style="font-size: clamp(2rem, 4vw, 3.25rem);">
            One file at a time. Each one locally valid.
          </p>
        </div>
        <div class="col-span-12 md:col-span-6 md:pl-10">
          <div class="tracked text-ochre-300 mb-3">AI sees</div>
          <p class="font-display italic text-ochre-300 leading-[1.15]" style="font-size: clamp(2rem, 4vw, 3.25rem);">
            The whole PR. The seams between files.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON CARDS -->
  <section class="max-w-[1320px] mx-auto px-6 md:px-10 py-16">
    <div class="space-y-6">
      {classes.map((c) => (
        <article class="border-2 border-ink-900 bg-paper-50 overflow-hidden">
          <header class="flex items-baseline justify-between gap-4 px-6 md:px-8 py-5 border-b border-ink-900/30 bg-paper-200">
            <div class="flex items-baseline gap-4">
              <span class="font-display italic text-oxblood-500 leading-none" style="font-size: clamp(2rem, 3vw, 2.75rem);">{c.n}</span>
              <h2 class="font-display tracking-tight text-ink-900 leading-tight" style="font-size: clamp(1.25rem, 2vw, 1.85rem);">{c.title}</h2>
            </div>
          </header>

          <div class="grid grid-cols-1 md:grid-cols-2">
            <div class="p-6 md:p-8 border-b md:border-b-0 md:border-r border-ink-900/20 bg-paper-50">
              <div class="flex items-center gap-2 mb-3">
                <span class="pill pill-medium">Linter sees</span>
              </div>
              <p class="text-ink-700 leading-[1.55] text-[15px]">{c.linterSees}</p>
            </div>
            <div class="p-6 md:p-8 bg-ink-950 text-paper-100">
              <div class="flex items-center gap-2 mb-3">
                <span class="pill pill-positive">AI sees</span>
              </div>
              <p class="text-paper-100 leading-[1.55] text-[15px]">{c.aiSees}</p>
            </div>
          </div>

          <div class="p-6 md:p-8 border-t border-ink-900/20">
            <div class="margin-note">Excerpt · review comment</div>
            <blockquote class="font-mono text-[12.5px] leading-[1.65] text-ink-700 mt-2 pl-4 border-l-2 border-oxblood-500">
              {c.sample}
            </blockquote>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
