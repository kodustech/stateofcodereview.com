---
import Layout from '../layouts/Layout.astro';

const classes = [
  { n: '01', title: 'Business logic duplicated across files', description: 'The same calculation, validation, or transformation implemented in multiple places. Hard for single-file linters to detect because each instance is locally correct.', sample: 'logica de negocio para definir que etapas de candidatos componen una metrica esta duplicada. en calculate-candidate-metrics index.ts se utiliza para sumar los totales mientras que en dashboard-analytics-dto.ts la misma logica' },
  { n: '02', title: 'Inconsistent handling of the same concept', description: 'Two functions that face the same situation but resolve it differently. One throws, one returns null. One handles the edge case, one does not.', sample: 'address schema() throws a badmethodcallexception which fails loudly. boleto schema() returns a null pattern that fails silently. inconsistent strategies make consumer behavior unpredictable' },
  { n: '03', title: 'Schema or config drift across modules', description: 'Library versions out of sync across files, validation schemas that contradict between create and update, environment variables defined inconsistently.', sample: 'as versoes do jaspersoft studio e jasperreports library estao inconsistentes entre os arquivos. o arquivo .jrxml menciona a versao 6.5.1 enquanto o .jasper menciona a versao 6.5.0' },
  { n: '04', title: 'Type incompatibility across packages', description: 'Interface defined in one package returns concrete types from another. The compile-time contract holds, the runtime behavior does not.', sample: 'type incompatibility between go.lumeweb.com queryutil and go.lumeweb.com queryutil filter packages. the dnsrecordparser returns concrete types from the filter subpackage but the dnsservice interface methods expect base types' },
  { n: '05', title: 'N+1 query split between controller and view', description: 'A controller eager-loads an association, but the view bypasses it via a scope that triggers fresh queries. The optimization in one file is undone by the other.', sample: 'consulta n+1 nao intencional. o controller pre-carrega a associacao historico_reajustes_ipca para evitar consultas extras. no entanto a view usa o escopo que dispara novas queries' },
  { n: '06', title: 'Test and code drift', description: 'Unit tests that pass against the old behavior of a refactored function, or backward-compatibility regressions where the test suite did not get the migration.', sample: 'backward-compatibility regression for analysis-results plot files. exportbutton.tsx and useoptimizationtabdata.ts now call downloadplotfile without legacy fallback so runs stored with the older naming will fail to export' },
];
---

<Layout
  title="What AI catches that linters cannot · State of AI Code Review"
  description="1,852 cross-file findings from production pull requests. Logic duplicated across files, schema drift, type incompatibility between packages, N+1 queries split between controller and view."
  runningHead="§ 03 Cross-file"
  page="Plate III"
>

  <section class="max-w-[1280px] mx-auto px-8 pt-16 md:pt-20 pb-12">
    <div class="grid grid-cols-12 gap-8 items-start">
      <div class="col-span-12 md:col-span-2">
        <div class="font-display italic text-oxblood-500 leading-none reveal reveal-1" style="font-size: clamp(5rem, 8vw, 7.5rem);">III</div>
        <div class="tracked text-ink-500 mt-3 reveal reveal-1">Plate III</div>
      </div>
      <div class="col-span-12 md:col-span-7">
        <div class="tracked text-ink-500 mb-4 reveal reveal-2">Chapter § 03 · Cross-file</div>
        <h1 class="font-display leading-[0.98] tracking-tight text-ink-900 reveal reveal-2" style="font-size: clamp(3rem, 7vw, 6rem);">
          What AI catches that <span class="italic">linters cannot.</span>
        </h1>
      </div>
      <aside class="col-span-12 md:col-span-3 md:pt-8 reveal reveal-3">
        <div class="border-l border-ink-900 pl-5">
          <p class="text-ink-700 leading-[1.6] text-[15px]">
            Single-file linters and human reviewers under time pressure tend to miss these. A linter analyzes one file at a time. A reviewer with 30 minutes for a 400-line diff cannot hold the whole codebase in their head. From 1,852 cross-file findings accepted by developers.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="max-w-[1280px] mx-auto px-8 pb-32">
    <div class="border-t-2 border-ink-900">
      {classes.map((c) => (
        <article class="border-b border-paper-300 py-14">
          <div class="grid grid-cols-12 gap-8">
            <div class="col-span-2 md:col-span-1">
              <div class="font-display italic text-oxblood-500 leading-none" style="font-size: clamp(2.25rem, 3.5vw, 3.5rem);">{c.n}</div>
            </div>
            <div class="col-span-10 md:col-span-7">
              <h2 class="font-display text-ink-900 tracking-tight leading-[1.05]" style="font-size: clamp(1.6rem, 2.5vw, 2.5rem);">{c.title}</h2>
              <p class="text-ink-700 leading-[1.7] mt-4 max-w-prose text-[16px]">{c.description}</p>
            </div>
            <div class="col-span-12 md:col-span-4">
              <div class="margin-note">Excerpt · review comment</div>
              <blockquote class="font-mono text-[12.5px] leading-[1.7] text-ink-700 mt-2 pl-4 border-l-2 border-oxblood-500">
                {c.sample}
              </blockquote>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
