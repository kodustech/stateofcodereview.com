---
import Layout from '../layouts/Layout.astro';

const chapters = [
  { num: '01', eyebrow: 'Bugs',            title: 'The 10 bugs AI catches most.',          metric: '90,527', metricLabel: 'bug findings',         href: '/bugs/' },
  { num: '02', eyebrow: 'Vulnerabilities', title: 'The 2026 vulnerability landscape.',     metric: '6,552',  metricLabel: 'security findings',    href: '/vulnerabilities/', tag: 'New · prompt injection' },
  { num: '03', eyebrow: 'Rules',           title: 'What 610 teams codified.',              metric: '7,276',  metricLabel: 'codified rules',       href: '/rules/' },
  { num: '04', eyebrow: 'Models',          title: 'Best LLM: 46%. Worst: 3%.',             metric: '79',     metricLabel: 'BYOK organizations',   href: '/models/' },
];

// Real data, modern 4-label scope (bug + security + performance + kody_rules)
const langs = [
  { name: 'Rust',       pct: 60.3, full: 35.9, n: 368   },
  { name: 'Elixir',     pct: 46.6, full: 19.5, n: 483   },
  { name: 'Go',         pct: 43.9, full: 26.5, n: 2942  },
  { name: 'Vue',        pct: 42.1, full: 22.8, n: 2808  },
  { name: 'TSX',        pct: 39.8, full: 24.8, n: 492   },
  { name: 'CSS',        pct: 38.3, full: 27.8, n: 209   },
  { name: 'PHP',        pct: 35.2, full: 12.2, n: 16492 },
  { name: 'Python',     pct: 35.1, full: 20.8, n: 9365  },
  { name: 'Ruby',       pct: 33.7, full: 15.3, n: 10411 },
  { name: 'TypeScript', pct: 32.7, full: 17.3, n: 66331 },
  { name: 'JavaScript', pct: 32.6, full: 14.8, n: 11524 },
  { name: 'Kotlin',     pct: 28.9, full: 16.2, n: 1153  },
];
---

<Layout
  page="Frontispiece"
  theme="dark"
>

  <!-- ─── HERO ─────────────────────────────────────────────────────── -->
  <section class="atmos gridfield border-b border-night-50 relative overflow-hidden" id="hero">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-12 md:pt-24 pb-16 md:pb-24 relative">

      <div class="flex items-center gap-3 mb-8 reveal reveal-1">
        <span class="cursor-blink phosphor">●</span>
        <span class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-phosphor-500">
          Live field report · MMXXVI · Q2
        </span>
      </div>

      <h1 class="font-display leading-[0.95] tracking-tight text-mist-50 reveal reveal-2 max-w-[16ch]"
          style="font-size: clamp(2.5rem, 8vw, 7rem); overflow-wrap: anywhere;">
        What happens after<br/>
        the AI <span class="italic phosphor">comment lands</span>?
      </h1>

      <p class="text-mist-200 text-[17px] md:text-[19px] leading-[1.55] max-w-2xl mt-8 reveal reveal-3">
        We read the post-PR diff for 162,262 AI code review suggestions across 464 engineering teams. This is what shipped on those lines.
      </p>

      <!-- Big stat + mini live data band -->
      <div class="mt-12 md:mt-16 grid grid-cols-12 gap-x-8 gap-y-10 items-end reveal reveal-4">
        <div class="col-span-12 lg:col-span-7">
          <div class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-mist-200 mb-3">
            Of every 100 delivered, this many earn a fix
          </div>
          <div class="flex items-baseline gap-2">
            <span class="font-display phosphor phosphor-pulse leading-none"
                  data-counter data-target="33"
                  style="font-size: clamp(7rem, 18vw, 14rem);">0</span>
            <span class="font-display phosphor leading-none" style="font-size: clamp(3rem, 7vw, 6rem);">%</span>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:pb-4">
          <div class="space-y-4">
            <div class="flex items-baseline justify-between border-b border-night-50 pb-3">
              <span class="font-mono text-[11px] font-medium tracking-[0.18em] uppercase text-mist-200">Suggestions</span>
              <span class="font-display text-mist-50 text-xl tabular-nums" id="live-suggestions">162,262</span>
            </div>
            <div class="flex items-baseline justify-between border-b border-night-50 pb-3">
              <span class="font-mono text-[11px] font-medium tracking-[0.18em] uppercase text-mist-200">Organizations</span>
              <span class="font-display text-mist-50 text-xl">464</span>
            </div>
            <div class="flex items-baseline justify-between border-b border-night-50 pb-3">
              <span class="font-mono text-[11px] font-medium tracking-[0.18em] uppercase text-mist-200">Window</span>
              <span class="font-mono text-mist-50 text-[13px]">Sep '25 → May '26</span>
            </div>
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-[11px] font-medium tracking-[0.18em] uppercase text-mist-200">Models seen</span>
              <span class="font-display text-mist-50 text-xl">20+</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Hero CTAs -->
      <div class="mt-12 md:mt-16 flex flex-wrap gap-3 reveal reveal-5">
        <a href="#demo"
           class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase bg-phosphor-500 text-night-200 px-6 py-3.5 hover:bg-phosphor-300 transition-colors">
          ↓ See it work
        </a>
        <a href="#chapters"
           class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-mist-50 border border-mist-400 px-6 py-3.5 hover:border-phosphor-500 hover:text-phosphor-500 transition-colors">
          Chapter index
        </a>
      </div>
    </div>
  </section>

  <!-- ─── LIVE DEMO ────────────────────────────────────────────────── -->
  <section id="demo" class="border-b border-night-50 bg-night-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-16 md:py-20">
      <div class="flex items-baseline justify-between mb-8 flex-wrap gap-3">
        <div class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-phosphor-500">
          ◆ Live · sample of what AI flags
        </div>
        <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-mist-400" id="demo-counter">01 / 04</div>
      </div>

      <div class="code-demo relative max-w-[920px]" id="code-demo">
        <!-- header -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-night-50">
          <div class="font-mono text-[11px] text-mist-200 truncate">
            <span class="text-phosphor-500">PR</span> <span class="text-mist-400">·</span>
            <span id="demo-file">packages/auth/login.ts</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-mist-200" id="demo-lang">typescript</span>
            <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" id="demo-severity"
                  style="background: var(--color-phosphor-500); color: var(--color-night-200);">critical</span>
          </div>
        </div>

        <!-- code -->
        <div class="py-3 overflow-x-auto" id="demo-code"></div>

        <!-- AI comment -->
        <div class="ai-card mx-4 mb-4 border border-phosphor-500/40 bg-night-100 p-4" id="demo-ai">
          <div class="flex items-baseline justify-between mb-2">
            <span class="font-mono text-[10px] font-medium tracking-[0.22em] uppercase text-phosphor-500">▌ AI · review comment</span>
            <span class="font-mono text-[10px] text-mist-400" id="demo-class">bug</span>
          </div>
          <p class="text-mist-200 text-[13.5px] leading-relaxed typing" id="demo-msg"></p>
        </div>

        <!-- Outcome stamp -->
        <div class="flex items-center justify-between px-4 py-3 border-t border-night-50">
          <div class="flex items-center gap-3 stamp-in" id="demo-outcome">
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase px-2 py-1"
                  id="demo-stamp"
                  style="background: oklch(45% 0.13 145 / 0.25); color: oklch(85% 0.15 145);">✓ applied</span>
            <span class="font-mono text-[11px] text-mist-200" id="demo-meta">1 of every 6 lands like this</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── IMPLEMENTATION RATE BY CLASS ─────────────────────────────── -->
  <section id="outcome" class="border-b border-night-50 bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20 md:py-28">

      <div class="grid grid-cols-12 gap-8 md:gap-12 items-end mb-12 md:mb-16">
        <div class="col-span-12 md:col-span-7">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-5">
            ◆ Implementation rate · by finding class
          </div>
          <h2 class="font-display leading-[0.98] tracking-tight text-mist-50" style="font-size: clamp(2rem, 5vw, 4rem); overflow-wrap: anywhere;">
            <span class="italic phosphor">Bugs at 33%.</span><br/>
            <span class="text-mist-200">Custom rules at 30%.</span>
          </h2>
        </div>
        <div class="col-span-12 md:col-span-5">
          <p class="text-mist-200 leading-[1.65] text-[15px] max-w-md">
            The 32% headline rate hides variance across categories. Bug findings lead. Custom rules — defined by the teams themselves — sit a step behind. Security trails despite being the highest-stakes class.
          </p>
        </div>
      </div>

      <div class="space-y-3 md:space-y-2">
        {[
          { label: 'Performance',   pct: 36.7, n: '4,265',  href: '/bugs/',           blurb: 'Caching, query patterns, async/await abuse' },
          { label: 'Bugs',          pct: 32.8, n: '90,527', href: '/bugs/',           blurb: 'Null access, race conditions, schema mismatches' },
          { label: 'Custom rules',  pct: 29.8, n: '60,918', href: '/rules/',          blurb: 'What 610 teams codified as their own enforcement layer' },
          { label: 'Security',      pct: 28.8, n: '6,552',  href: '/vulnerabilities/',blurb: 'SQL injection, path traversal, prompt injection (new in 2026)' },
        ].map((row, i) => (
          <a href={row.href} class="group block border-b border-night-50 py-5 md:py-6 hover:bg-night-200/40 transition-colors -mx-3 md:-mx-6 px-3 md:px-6">
            <div class="grid grid-cols-12 gap-3 md:gap-6 items-baseline">
              <div class="col-span-12 md:col-span-3">
                <div class="font-display text-mist-50 text-[24px] md:text-[28px] leading-none group-hover:text-phosphor-500 transition-colors">{row.label}</div>
                <div class="font-mono text-[11px] font-medium tracking-[0.18em] uppercase text-mist-400 mt-2">{row.n} delivered</div>
              </div>
              <div class="col-span-8 md:col-span-6">
                <div class="h-[3px] bg-night-50 relative">
                  <div class="absolute inset-y-0 left-0 bar-grow" style={`background: var(--color-phosphor-500); width: ${(row.pct / 50) * 100}%; animation-delay: ${i * 0.12}s;`}></div>
                </div>
                <div class="font-mono text-[12px] text-mist-200 mt-3">{row.blurb}</div>
              </div>
              <div class="col-span-3 md:col-span-2 text-right">
                <span class="font-display phosphor leading-none" style="font-size: clamp(2rem, 3.5vw, 3rem);">{row.pct}%</span>
              </div>
              <div class="col-span-1 text-right font-mono text-[12px] text-mist-400 group-hover:text-phosphor-500 transition-colors">
                →
              </div>
            </div>
          </a>
        ))}
      </div>

      <p class="font-mono text-[11px] text-mist-400 mt-10 max-w-3xl">
        Rate = (fully implemented + partially implemented) / delivered. Computed from the post-PR diff, full population. Bar scales 0–50%.
      </p>
    </div>
  </section>

  <!-- ─── CHAPTERS ─────────────────────────────────────────────────── -->
  <section id="chapters" class="bg-night-200 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20 md:py-28">

      <div class="flex items-baseline justify-between mb-12 md:mb-16 flex-wrap gap-4">
        <h2 class="font-display italic text-mist-50" style="font-size: clamp(2rem, 4vw, 3.25rem);">
          Four chapters.
        </h2>
        <span class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-mist-200">// 01–04</span>
      </div>

      <div class="grid grid-cols-1 gap-px bg-night-50">
        {chapters.map((c) => (
          <a href={c.href} class="group glow-on-hover relative bg-night-200 border border-night-50 px-6 md:px-10 py-8 md:py-10 block">
            <div class="grid grid-cols-12 gap-4 md:gap-6 items-baseline">
              <div class="col-span-2 md:col-span-1 font-mono text-mist-400 text-sm tracking-wider group-hover:text-phosphor-500 transition-colors">
                {c.num}
              </div>
              <div class="col-span-10 md:col-span-6">
                <div class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-mist-200 mb-2 group-hover:text-phosphor-500 transition-colors">
                  {c.eyebrow}
                </div>
                <h3 class="font-display tracking-tight leading-[1.05] text-mist-50 group-hover:text-phosphor-500 transition-colors" style="font-size: clamp(1.5rem, 2.4vw, 2.25rem); overflow-wrap: anywhere;">
                  {c.title}
                </h3>
                {c.tag && (
                  <span class="inline-block mt-3 font-mono text-[10px] tracking-[0.18em] uppercase text-night-200 bg-phosphor-500 px-2 py-1">
                    {c.tag}
                  </span>
                )}
              </div>
              <div class="col-span-9 md:col-span-4 md:text-right md:pl-6">
                <div class="font-display text-mist-50" style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1;">{c.metric}</div>
                <div class="font-mono text-[10px] font-medium tracking-[0.18em] uppercase text-mist-400 mt-1">{c.metricLabel}</div>
              </div>
              <div class="col-span-3 md:col-span-1 text-right font-mono text-mist-400 text-sm group-hover:text-phosphor-500 transition-colors">
                →
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── LANGUAGE STRIP ───────────────────────────────────────────── -->
  <section class="bg-night-100 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20 md:py-28">

      <div class="grid grid-cols-12 gap-8 md:gap-10 items-baseline mb-12">
        <div class="col-span-12 md:col-span-8">
          <div class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-4">
            ◆ Implementation rate · by language
          </div>
          <h2 class="font-display leading-[1.0] tracking-tight text-mist-50" style="font-size: clamp(2rem, 4.5vw, 3.75rem); overflow-wrap: anywhere;">
            <span class="phosphor italic">Rust at 60%.</span>
            <span class="text-mist-200">Kotlin at 29%.</span>
          </h2>
        </div>
        <div class="col-span-12 md:col-span-4">
          <p class="text-mist-200 leading-[1.65] text-[14px]">
            Compiled and strongly-typed languages cluster at the top. The variance is real: a 30-point spread between Rust and Kotlin on the same engine.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-2">
        {langs.map((l) => (
          <div class="grid grid-cols-12 gap-3 md:gap-4 items-center py-2">
            <div class="col-span-3 md:col-span-2 font-display text-mist-50 text-[17px] md:text-[18px]">{l.name}</div>
            <div class="col-span-6 md:col-span-8">
              <div class="relative h-px bg-night-50">
                <div class="absolute inset-y-0 left-0 bar-grow" style={`background: var(--color-phosphor-500); width: ${(l.pct / 65) * 100}%; height: 1px;`}></div>
              </div>
            </div>
            <div class="col-span-3 md:col-span-2 text-right">
              <span class="font-mono text-phosphor-500 text-[13px] md:text-[14px]">{l.pct}%</span>
              <span class="font-mono text-mist-400 text-[10px] ml-2 hidden md:inline">{l.n.toLocaleString()}</span>
            </div>
          </div>
        ))}
      </div>

      <p class="font-mono text-[10.5px] tracking-wide text-mist-400 mt-8">
        Languages with ≥ 200 delivered suggestions and ≥ 5 distinct organizations. Bar scales 0–65%. Source: query 09.
      </p>
    </div>
  </section>

  <!-- ─── MODEL PROVOCATION ────────────────────────────────────────── -->
  <section class="bg-night-200 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20 md:py-28">
      <div class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-6">
        ◆ Chapter 04 preview
      </div>
      <div class="grid grid-cols-12 gap-8 md:gap-12 items-start">
        <div class="col-span-12 md:col-span-7">
          <h2 class="font-display leading-[0.95] tracking-tight text-mist-50" style="font-size: clamp(2rem, 5vw, 4.5rem); overflow-wrap: anywhere;">
            The model barely <span class="italic phosphor">matters.</span>
          </h2>
          <p class="text-mist-200 leading-[1.65] text-[15px] md:text-[16px] mt-6 max-w-xl">
            79 teams running 5 providers and 20+ distinct models. Anthropic, Gemini and OpenAI all land within 4 percentage points of each other. What predicts higher rates is how the team tunes their prompts and review rules — not which API they call.
          </p>
          <a href="/models/" class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-phosphor-500 hover:text-phosphor-300 mt-10 inline-block">
            Read chapter 04 →
          </a>
        </div>
        <div class="col-span-12 md:col-span-5">
          <div class="space-y-1">
            {[
              { name: 'ANTHROPIC',  pct: 21.2, w: 84 },
              { name: 'GEMINI',     pct: 20.5, w: 82 },
              { name: 'OPENAI',     pct: 17.8, w: 71 },
              { name: 'SELF-HOST',  pct: 15.4, w: 62, dim: true },
            ].map((p, i) => (
              <div class="grid grid-cols-12 gap-3 items-baseline py-3 border-b border-night-50 last:border-b-0">
                <span class="font-mono text-[11px] text-mist-200 col-span-3">{p.name}</span>
                <div class="col-span-7 h-px bg-night-50 relative">
                  <div class="absolute inset-y-0 left-0 bar-grow" style={`background: ${p.dim ? 'var(--color-mist-400)' : 'var(--color-phosphor-500)'}; width: ${p.w}%; height: 1px; animation-delay: ${i * 0.1}s;`}></div>
                </div>
                <span class={`font-display ${p.dim ? 'text-mist-400' : 'phosphor'} col-span-2 text-right`}>{p.pct}%</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CITATION ─────────────────────────────────────────────────── -->
  <section class="bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-16 md:py-20">
      <div class="grid grid-cols-12 gap-8 md:gap-10 items-end">
        <div class="col-span-12 md:col-span-6">
          <div class="font-mono text-[11px] font-medium tracking-[0.22em] uppercase text-mist-200 mb-4">// Cite this</div>
          <h2 class="font-display italic text-mist-50" style="font-size: clamp(1.5rem, 2.5vw, 2rem);">
            Reuse with attribution.
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6">
          <pre class="font-mono text-[12px] leading-relaxed text-mist-200 bg-night-200 border-l-2 border-phosphor-500 p-5 overflow-x-auto">State of AI Code Review (2026-Q2).
Research by Kodus.
https://stateofcodereview.com</pre>
          <div class="mt-5 flex gap-6 flex-wrap font-mono text-[11px] font-medium tracking-[0.22em] uppercase">
            <a href="/methodology/" class="text-mist-200 hover:text-phosphor-500">→ Methodology</a>
            <a href="https://github.com/kodustech/stateofcodereview.com" class="text-mist-200 hover:text-phosphor-500">→ GitHub repo</a>
            <a href="https://creativecommons.org/licenses/by/4.0/" class="text-mist-200 hover:text-phosphor-500">→ CC BY 4.0</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contextual scripts -->
  <script is:inline>
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ─── Mouse-follow atmospheric glow on hero ──────────────────────────
    const hero = document.getElementById('hero');
    if (hero && !reducedMotion) {
      hero.addEventListener('pointermove', (e) => {
        const rect = hero.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        hero.style.setProperty('--mx', x + '%');
        hero.style.setProperty('--my', y + '%');
      }, { passive: true });
    }

    // ─── Counter animation via rAF ─────────────────────────────────────
    function animateCounter(el, target, duration) {
      if (reducedMotion) { el.textContent = String(target); return; }
      const start = performance.now();
      function tick(now) {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(eased * target);
        if (t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
    const counters = document.querySelectorAll('[data-counter]');
    if (counters.length) {
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const target = parseInt(entry.target.dataset.target || '0', 10);
              animateCounter(entry.target, target, 1600);
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.35 });
        counters.forEach((c) => io.observe(c));
      } else {
        counters.forEach((c) => {
          const target = parseInt(c.dataset.target || '0', 10);
          c.textContent = String(target);
        });
      }
    }

    // ─── Live code review demo ─────────────────────────────────────────
    const demo = document.getElementById('code-demo');
    if (demo) {
      const examples = [
        {
          file: 'packages/auth/login.ts:42', lang: 'typescript', cls: 'bug', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 40, t: 'function authenticate(token: string) {' },
            { n: 41, t: '  const user = db.users.find({ token });' },
            { n: 42, t: '  return user.session.id;', state: 'minus' },
            { n: 42, t: '  if (!user) throw new Error("Invalid token");', state: 'plus' },
            { n: 43, t: '  return user.session.id;', state: 'plus' },
            { n: 44, t: '}' },
          ],
          msg: 'Missing null check on user. db.users.find returns null for unknown tokens, and user.session.id will throw at runtime.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: 'bug findings: 33% land like this',
        },
        {
          file: 'internal/sql/repo.go:87', lang: 'go', cls: 'security', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 85, t: 'func GetUser(name string) (*User, error) {' },
            { n: 86, t: '  q := fmt.Sprintf("SELECT * FROM users WHERE name = \'%s\'", name)', state: 'flag' },
            { n: 87, t: '  return db.QueryRow(q).Scan(&u)', state: 'minus' },
            { n: 86, t: '  return db.QueryRow("SELECT * FROM users WHERE name = $1", name).Scan(&u)', state: 'plus' },
            { n: 88, t: '}' },
          ],
          msg: 'SQL injection: name is interpolated directly into the query. Use a parameterized query with $1 binding.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: 'security: 65% acceptance on critical',
        },
        {
          file: 'api/users/handler.py:45', lang: 'python', cls: 'bug', sev: 'high',
          severityColor: 'oklch(86% 0.14 80)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 43, t: 'async def get_certificate(user_id):' },
            { n: 44, t: '  cached = cache.get(user_id)' },
            { n: 45, t: '  if cached: return cached', state: 'flag' },
            { n: 46, t: '  cert = await issue_cert(user_id)' },
            { n: 47, t: '  cache.set(user_id, cert)' },
            { n: 48, t: '  return cert' },
          ],
          msg: 'Race condition: two concurrent requests for the same user will both call issue_cert(). Wrap the cache check + issue in an asyncio.Lock keyed by user_id.',
          stamp: '~ adapted', stampBg: 'oklch(78% 0.18 75 / 0.18)', stampColor: 'var(--color-phosphor-500)',
          meta: 'dev applied a different fix on these lines',
        },
        {
          file: 'src/prompts/system.py:18', lang: 'python', cls: 'security', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 16, t: 'def build_prompt(user_input, request_data):' },
            { n: 17, t: '  return f"""You are a helpful assistant.', state: 'minus' },
            { n: 18, t: '  Request: {request_data}', state: 'minus' },
            { n: 19, t: '  Input: {user_input}"""', state: 'minus' },
            { n: 17, t: '  return SYSTEM + delimit(user_input) + delimit(request_data)', state: 'plus' },
          ],
          msg: 'Prompt injection: user_input concatenated into the system prompt without delimiters. Sanitize and wrap user-controlled strings in dedicated boundaries.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: 'prompt injection · new top-10 class in 2026',
        },
      ];

      const fileEl  = document.getElementById('demo-file');
      const langEl  = document.getElementById('demo-lang');
      const sevEl   = document.getElementById('demo-severity');
      const codeEl  = document.getElementById('demo-code');
      const aiEl    = document.getElementById('demo-ai');
      const msgEl   = document.getElementById('demo-msg');
      const classEl = document.getElementById('demo-class');
      const outcEl  = document.getElementById('demo-outcome');
      const stampEl = document.getElementById('demo-stamp');
      const metaEl  = document.getElementById('demo-meta');
      const idxEl   = document.getElementById('demo-counter');

      let idx = 0;
      function typeMessage(text, el, speed = 16, done) {
        el.textContent = '';
        el.classList.add('typing');
        if (reducedMotion) { el.textContent = text; el.classList.remove('typing'); if (done) done(); return; }
        let i = 0;
        (function step() {
          if (i <= text.length) {
            el.textContent = text.slice(0, i);
            i++;
            setTimeout(step, speed);
          } else {
            el.classList.remove('typing');
            if (done) done();
          }
        })();
      }
      function render(ex) {
        fileEl.textContent  = ex.file;
        langEl.textContent  = ex.lang;
        sevEl.textContent   = ex.sev;
        sevEl.style.background = ex.severityColor;
        sevEl.style.color      = ex.severityText;
        classEl.textContent = ex.cls;
        idxEl.textContent   = `${String(idx + 1).padStart(2, '0')} / ${String(examples.length).padStart(2, '0')}`;

        codeEl.innerHTML = '';
        ex.lines.forEach((ln, i) => {
          const span = document.createElement('span');
          const stateCls = ln.state === 'minus' ? 'line-minus' : ln.state === 'plus' ? 'line-plus' : ln.state === 'flag' ? 'line-flag' : '';
          span.className = `code-line line-num anim-line ${stateCls}`;
          span.setAttribute('data-ln', ln.n);
          span.style.animationDelay = `${i * 0.06}s`;
          const prefix = ln.state === 'minus' ? '- ' : ln.state === 'plus' ? '+ ' : '  ';
          span.textContent = prefix + ln.t;
          codeEl.appendChild(span);
        });

        aiEl.classList.remove('ai-card');
        void aiEl.offsetWidth;
        aiEl.classList.add('ai-card');

        outcEl.classList.remove('stamp-in');
        void outcEl.offsetWidth;
        outcEl.classList.add('stamp-in');
        stampEl.textContent       = ex.stamp;
        stampEl.style.background  = ex.stampBg;
        stampEl.style.color       = ex.stampColor;
        metaEl.textContent        = ex.meta;

        const linesDoneAt = ex.lines.length * 60 + 200;
        setTimeout(() => typeMessage(ex.msg, msgEl, 16), linesDoneAt);
      }
      function next() {
        render(examples[idx % examples.length]);
        idx++;
      }
      next();
      if (!reducedMotion) {
        setInterval(next, 8500);
      }
    }

    // ─── Live suggestion counter ──────────────────────────────────────
    const liveSuggestions = document.getElementById('live-suggestions');
    if (liveSuggestions && !reducedMotion) {
      let value = 162262;
      setInterval(() => {
        if (Math.random() > 0.5) {
          value += Math.floor(Math.random() * 3) + 1;
          liveSuggestions.textContent = value.toLocaleString('en-US');
        }
      }, 4200);
    }
  </script>
</Layout>
