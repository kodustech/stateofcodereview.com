---
import Layout from '../layouts/Layout.astro';

const chapters = [
  { num: '01', eyebrow: 'Bugs',            title: 'The 10 bugs AI catches most.',          metric: '90,527', metricLabel: 'bug findings',         href: '/bugs/' },
  { num: '02', eyebrow: 'Vulnerabilities', title: 'The 2026 vulnerability landscape.',     metric: '6,552',  metricLabel: 'security findings',    href: '/vulnerabilities/', tag: 'New · prompt injection' },
  { num: '03', eyebrow: 'Cross-file',      title: 'What AI catches that linters cannot.',  metric: '10,992', metricLabel: 'cross-file findings',  href: '/cross-file/' },
  { num: '04', eyebrow: 'Rules',           title: 'What 610 teams codified.',              metric: '7,276',  metricLabel: 'codified rules',       href: '/rules/' },
  { num: '05', eyebrow: 'Models',          title: 'Best LLM: 28%. Worst: 3%.',             metric: '79',     metricLabel: 'BYOK organizations',   href: '/models/' },
];

const langs = [
  { name: 'Rust',       pct: 37.6 },
  { name: 'Go',         pct: 29.1 },
  { name: 'Vue',        pct: 25.2 },
  { name: 'Python',     pct: 20.5 },
  { name: 'TypeScript', pct: 18.5 },
  { name: 'JavaScript', pct: 16.3 },
  { name: 'Ruby',       pct: 15.4 },
  { name: 'PHP',        pct: 13.0 },
  { name: 'Java',       pct: 12.7 },
  { name: 'C#',         pct: 12.7 },
];
---

<Layout
  page="Frontispiece"
  theme="dark"
>

  <!-- ─── HERO ─────────────────────────────────────────────────────── -->
  <section class="atmos gridfield border-b border-night-50 relative overflow-hidden" id="hero">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-20 md:pb-28 relative">

      <div class="flex items-center gap-3 mb-8 reveal reveal-1">
        <span class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.22em] uppercase text-phosphor-500">
          <span class="cursor-blink">●</span> Live field report · MMXXVI · Q2
        </span>
      </div>

      <h1 class="font-display leading-[0.94] tracking-tight text-mist-50 reveal reveal-2 max-w-5xl"
          style="font-size: clamp(2.5rem, 7vw, 6rem);">
        What happens after<br/>
        the AI <span class="italic phosphor">comment lands</span>?
      </h1>

      <p class="text-mist-200 text-[17px] md:text-[19px] leading-[1.55] max-w-2xl mt-8 reveal reveal-3">
        We read the post-PR diff for 112,336 AI code review suggestions across 456 engineering teams. This is what shipped on those lines.
      </p>

      <!-- Demo + Counter grid -->
      <div class="mt-14 md:mt-20 grid grid-cols-12 gap-8 lg:gap-12 items-start reveal reveal-4">

        <!-- LEFT: Code review demo (live, rotating) -->
        <div class="col-span-12 lg:col-span-8">
          <div class="code-demo relative" id="code-demo">

            <!-- header -->
            <div class="flex items-center justify-between px-4 py-3 border-b border-night-50">
              <div class="font-mono text-[11px] text-mist-400 truncate">
                <span class="text-phosphor-500">PR</span> <span class="text-mist-600">·</span>
                <span id="demo-file">packages/auth/login.ts</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-mist-400" id="demo-lang">typescript</span>
                <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" id="demo-severity"
                      style="background: var(--color-phosphor-500); color: var(--color-night-200);">critical</span>
              </div>
            </div>

            <!-- code -->
            <div class="py-3" id="demo-code"></div>

            <!-- AI comment -->
            <div class="ai-card mx-4 mb-4 border border-phosphor-500/40 bg-night-100 p-4" id="demo-ai">
              <div class="flex items-baseline justify-between mb-2">
                <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-phosphor-500">▌ AI · review comment</span>
                <span class="font-mono text-[10px] text-mist-600" id="demo-class">bug</span>
              </div>
              <p class="text-mist-200 text-[13.5px] leading-relaxed typing" id="demo-msg"></p>
            </div>

            <!-- Outcome stamp -->
            <div class="flex items-center justify-between px-4 py-3 border-t border-night-50">
              <div class="flex items-center gap-3 stamp-in" id="demo-outcome" key>
                <span class="font-mono text-[10px] tracking-[0.22em] uppercase px-2 py-1"
                      id="demo-stamp"
                      style="background: oklch(45% 0.13 145 / 0.25); color: oklch(85% 0.15 145);">✓ applied</span>
                <span class="font-mono text-[11px] text-mist-400" id="demo-meta">1 of every 6 lands like this</span>
              </div>
              <div class="font-mono text-[10px] text-mist-600" id="demo-counter">01 / 04</div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Counter + stats -->
        <div class="col-span-12 lg:col-span-4">
          <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-400 mb-4">
            Of every 100 delivered
          </div>
          <div class="flex items-baseline gap-2">
            <span class="font-display phosphor phosphor-pulse leading-none"
                  data-counter data-target="33"
                  style="font-size: clamp(6rem, 12vw, 10rem);">0</span>
            <span class="font-display phosphor leading-none" style="font-size: clamp(2.5rem, 5vw, 4rem);">%</span>
          </div>
          <div class="text-mist-200 text-[15px] leading-relaxed mt-5 max-w-sm">
            earn a fix from the developer.
          </div>

          <div class="mt-10 space-y-4 border-t border-night-50 pt-6">
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-400">Suggestions</span>
              <span class="font-display text-mist-50 text-xl tabular-nums" id="live-suggestions">112,336</span>
            </div>
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-400">Organizations</span>
              <span class="font-display text-mist-50 text-xl">456</span>
            </div>
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-400">Window</span>
              <span class="font-mono text-mist-50 text-[13px]">Sep '25 → May '26</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Hero CTAs -->
      <div class="mt-14 flex flex-wrap gap-3 reveal reveal-5">
        <a href="#outcome"
           class="font-mono text-[11px] tracking-[0.22em] uppercase bg-phosphor-500 text-night-200 px-6 py-3.5 hover:bg-phosphor-300 transition-colors">
          ↓ See the breakdown
        </a>
        <a href="/bugs/"
           class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-50 border border-mist-400 px-6 py-3.5 hover:border-phosphor-500 hover:text-phosphor-500 transition-colors">
          Read chapter 01 →
        </a>
      </div>
    </div>
  </section>

  <!-- ─── OUTCOME SPLIT ────────────────────────────────────────────── -->
  <section id="outcome" class="border-b border-night-50 bg-night-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32">

      <div class="grid grid-cols-12 gap-12 items-start mb-16">
        <div class="col-span-12 md:col-span-6">
          <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-6">
            ◆ The 33%
          </div>
          <h2 class="font-display leading-[0.98] tracking-tight text-mist-50" style="font-size: clamp(2rem, 5vw, 4rem);">
            Half land <span class="italic phosphor">exactly</span> as written.<br/>
            Half get <span class="italic" style="color: var(--color-signal-cyan);">adapted</span> by the dev.
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:pt-4">
          <p class="text-mist-400 leading-[1.7] text-[15px] max-w-md">
            Implementation status comes from the actual post-PR diff. We compared the suggested code against what shipped on those exact lines.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-12 gap-x-12 gap-y-10">
        <div class="col-span-12 md:col-span-6 group">
          <div class="flex items-baseline justify-between mb-4">
            <div>
              <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600">Applied exactly</div>
              <div class="font-display phosphor mt-2" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1;">17%</div>
            </div>
            <div class="font-mono text-xs text-mist-600">~19,107 / 112,336</div>
          </div>
          <div class="h-[2px] bg-night-50 relative overflow-hidden">
            <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-phosphor-500); width: 51%;"></div>
          </div>
          <p class="text-mist-400 text-[13px] mt-4 leading-relaxed">
            Dev pasted or kept the suggested code as-is on the flagged lines.
          </p>
        </div>

        <div class="col-span-12 md:col-span-6 group">
          <div class="flex items-baseline justify-between mb-4">
            <div>
              <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600">Adapted to fit</div>
              <div class="font-display mt-2" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1; color: var(--color-signal-cyan);">16%</div>
            </div>
            <div class="font-mono text-xs text-mist-600">~18,390 / 112,336</div>
          </div>
          <div class="h-[2px] bg-night-50 relative overflow-hidden">
            <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-signal-cyan); width: 49%; animation-delay: 0.25s;"></div>
          </div>
          <p class="text-mist-400 text-[13px] mt-4 leading-relaxed">
            Dev took the idea and rewrote those lines in their own way.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CHAPTERS ─────────────────────────────────────────────────── -->
  <section class="bg-night-100 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32">

      <div class="flex items-baseline justify-between mb-16 flex-wrap gap-4">
        <h2 class="font-display italic text-mist-50" style="font-size: clamp(2rem, 4vw, 3.25rem);">
          Five chapters.
        </h2>
        <span class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600">// 01–05</span>
      </div>

      <div class="grid grid-cols-1 gap-px bg-night-50">
        {chapters.map((c) => (
          <a href={c.href} class="group glow-on-hover relative bg-night-100 border border-night-50 px-6 md:px-10 py-10 block">
            <div class="grid grid-cols-12 gap-6 items-baseline">
