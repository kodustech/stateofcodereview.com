---
import Layout from '../layouts/Layout.astro';

const chapters = [
  { num: '01', eyebrow: 'Bugs',            title: 'The 10 bugs AI catches most in production code.',  metric: '90,527', label: 'findings', href: '/bugs/' },
  { num: '02', eyebrow: 'Vulnerabilities', title: 'The 2026 vulnerability landscape.',                 metric: '6,552',  label: 'findings', href: '/vulnerabilities/', tag: 'new class · prompt injection' },
  { num: '03', eyebrow: 'Rules',           title: 'What 610 engineering teams codified.',              metric: '7,276',  label: 'rules',    href: '/rules/' },
  { num: '04', eyebrow: 'Models',          title: 'Best LLM: 46%. Worst: 3%.',                         metric: '79',     label: 'BYOK orgs', href: '/models/' },
];

const breakdown = [
  { label: 'Performance',   pct: 36.7, n: '4,265',  href: '/bugs/' },
  { label: 'Bugs',          pct: 32.8, n: '90,527', href: '/bugs/' },
  { label: 'Custom rules',  pct: 29.8, n: '60,918', href: '/rules/' },
  { label: 'Security',      pct: 28.8, n: '6,552',  href: '/vulnerabilities/' },
];

const langs = [
  { name: 'Rust',       pct: 60.3, n: 368   },
  { name: 'Elixir',     pct: 46.6, n: 483   },
  { name: 'Go',         pct: 43.9, n: 2942  },
  { name: 'Vue',        pct: 42.1, n: 2808  },
  { name: 'TSX',        pct: 39.8, n: 492   },
  { name: 'CSS',        pct: 38.3, n: 209   },
  { name: 'PHP',        pct: 35.2, n: 16492 },
  { name: 'Python',     pct: 35.1, n: 9365  },
  { name: 'Ruby',       pct: 33.7, n: 10411 },
  { name: 'TypeScript', pct: 32.7, n: 66331 },
  { name: 'JavaScript', pct: 32.6, n: 11524 },
  { name: 'Kotlin',     pct: 28.9, n: 1153  },
];

const modelRows = [
  { model: 'Kimi K2.5 (NVFP4)',         endpoint: 'Synthetic.new',     pct: 46.2 },
  { model: 'Kimi K2.5',                 endpoint: 'OpenRouter',        pct: 46.2 },
  { model: 'GPT-5.2 Codex',             endpoint: 'OpenAI direct',     pct: 29.3 },
  { model: 'Claude Opus 4.5',           endpoint: 'Anthropic direct',  pct: 27.2 },
  { model: 'KAT Coder Pro',             endpoint: 'OpenRouter',        pct: 24.8 },
  { model: 'Gemini 2.5 Flash',          endpoint: 'Google direct',     pct: 24.2 },
  { model: 'Claude Sonnet 4.5',         endpoint: 'Anthropic direct',  pct: 22.9 },
  { model: 'Gemini 3 Flash Preview',    endpoint: 'Google direct',     pct: 21.7 },
];
---

<Layout
  page="Frontispiece"
  theme="dark"
>

  <!-- ─── HERO · oversized editorial ───────────────────────────────── -->
  <section class="atmos mesh-bg border-b border-night-50 relative overflow-hidden" id="hero">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 pt-10 md:pt-16 pb-16 md:pb-20 relative">

      <!-- Top metadata strip -->
      <div class="flex items-baseline justify-between font-mono text-[10.5px] tracking-[0.2em] uppercase text-mist-400 mb-12 md:mb-16 reveal reveal-1">
        <span class="flex items-center gap-2.5">
          <span class="cursor-blink phosphor">●</span>
          <span class="text-mist-200">Snapshot 2026-Q2</span>
        </span>
        <span class="hidden md:inline">
          <span class="text-mist-600">Frozen</span> 2026-05-19
        </span>
      </div>

      <!-- Massive editorial headline · asymmetric -->
      <div class="grid grid-cols-12 gap-y-12 gap-x-8 items-start">
        <div class="col-span-12 md:col-span-12 lg:col-span-7">
          <h1 class="font-display tracking-tight text-mist-50 reveal reveal-2"
              style="font-size: clamp(3.25rem, 11vw, 11rem); line-height: 0.92; overflow-wrap: anywhere;">
            What happens<br/>
            after the<br/>
            <span class="italic phosphor">AI comment</span><br/>
            lands<span class="phosphor">?</span>
          </h1>
        </div>

        <aside class="col-span-12 lg:col-span-5 lg:pl-8 lg:pt-6 reveal reveal-3">
          <p class="text-mist-200 leading-[1.5] text-[18px] md:text-[20px] max-w-md">
            We read the post-PR diff for <span class="text-mist-50 font-medium">162,262</span> AI code review suggestions across <span class="text-mist-50 font-medium">464</span> engineering teams. This is what shipped on those exact lines.
          </p>
        </aside>
      </div>

      <!-- Stat slab + persistent demo, side by side -->
      <div class="mt-20 md:mt-28 grid grid-cols-12 gap-y-12 gap-x-8 items-end reveal reveal-4">

        <!-- Big architectural counter -->
        <div class="col-span-12 lg:col-span-5">
          <div class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-mist-200 mb-3">
            Of every 100 delivered <span class="text-mist-400">·</span> earn a fix
          </div>
          <div class="flex items-baseline gap-2">
            <span class="archi-num phosphor-pulse"
                  data-counter data-target="33"
                  style="font-size: clamp(8rem, 22vw, 18rem);">0</span>
            <span class="archi-num leading-none" style="font-size: clamp(3rem, 8vw, 7rem);">%</span>
          </div>

          <div class="mt-10 grid grid-cols-3 gap-3 max-w-xl">
            <div class="border-t border-night-50 pt-3">
              <div class="font-display text-mist-50 text-[22px] md:text-[26px] leading-none tabular-nums" id="live-suggestions">162,262</div>
              <div class="font-mono text-[9.5px] tracking-[0.18em] uppercase text-mist-400 mt-2">Suggestions</div>
            </div>
            <div class="border-t border-night-50 pt-3">
              <div class="font-display text-mist-50 text-[22px] md:text-[26px] leading-none">464</div>
              <div class="font-mono text-[9.5px] tracking-[0.18em] uppercase text-mist-400 mt-2">Organizations</div>
            </div>
            <div class="border-t border-night-50 pt-3">
              <div class="font-display text-mist-50 text-[22px] md:text-[26px] leading-none">20+</div>
              <div class="font-mono text-[9.5px] tracking-[0.18em] uppercase text-mist-400 mt-2">LLM models</div>
            </div>
          </div>
        </div>

        <!-- Persistent terminal demo -->
        <div class="col-span-12 lg:col-span-7">
          <div class="code-demo" id="code-demo">
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-night-50">
              <div class="font-mono text-[10.5px] text-mist-200 truncate flex items-center gap-2">
                <span class="cursor-blink phosphor">▌</span>
                <span class="text-phosphor-500">live</span>
                <span class="text-mist-600">·</span>
                <span id="demo-file">packages/auth/login.ts</span>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-mist-200" id="demo-lang">typescript</span>
                <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" id="demo-severity"
                      style="background: var(--color-phosphor-500); color: var(--color-night-200);">critical</span>
              </div>
            </div>

            <div class="py-3 overflow-x-auto min-h-[180px]" id="demo-code"></div>

            <div class="ai-card mx-3 mb-3 border border-phosphor-500/40 bg-night-100 p-3.5" id="demo-ai">
              <div class="flex items-baseline justify-between mb-1.5">
                <span class="font-mono text-[9.5px] tracking-[0.22em] uppercase text-phosphor-500">▌ AI · review comment</span>
                <span class="font-mono text-[9.5px] text-mist-400" id="demo-class">bug</span>
              </div>
              <p class="text-mist-200 text-[12.5px] leading-relaxed typing" id="demo-msg"></p>
            </div>

            <div class="flex items-center justify-between px-4 py-2.5 border-t border-night-50">
              <div class="flex items-center gap-3 stamp-in" id="demo-outcome">
                <span class="font-mono text-[10px] tracking-[0.22em] uppercase px-2 py-1"
                      id="demo-stamp"
                      style="background: oklch(45% 0.13 145 / 0.25); color: oklch(85% 0.15 145);">✓ applied</span>
                <span class="font-mono text-[10.5px] text-mist-200" id="demo-meta">bug findings: 33% land like this</span>
              </div>
              <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-mist-400" id="demo-counter">01 / 04</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── THE BREAKDOWN · asymmetric editorial spread ──────────────── -->
  <section id="outcome" class="border-b border-night-50 bg-night-200">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 py-20 md:py-32">
      <div class="grid grid-cols-12 gap-y-12 gap-x-8">

        <!-- Left rail: pull-quote + aside -->
        <div class="col-span-12 lg:col-span-4 lg:sticky lg:top-12 self-start">
          <div class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-phosphor-500 mb-5">
            ◆ the 33%
          </div>
          <h2 class="font-display text-mist-50 tracking-tight leading-[0.95]" style="font-size: clamp(2.25rem, 5.5vw, 4.5rem); overflow-wrap: anywhere;">
            <span class="italic phosphor">1 in 3</span><br/>
            earns a fix.<br/>
            <span class="text-mist-400">2 in 3</span><br/>
            <span class="text-mist-400">don't.</span>
          </h2>
          <div class="aside mt-8 max-w-xs">
            measured from the post-PR diff, not opt-in feedback. every suggestion that reached a developer is counted — silent ignores included.
          </div>
        </div>

        <!-- Right rail: the table -->
        <div class="col-span-12 lg:col-span-8">
          <div class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-mist-200 mb-6 flex justify-between">
            <span>finding class</span>
            <span>implementation rate</span>
          </div>

          <div class="border-t border-night-50">
            {breakdown.map((row, i) => (
              <a href={row.href} class="data-row group block hover:bg-night-100" style="grid-template-columns: 1fr auto;">
                <div class="px-2">
                  <div class="font-display text-mist-50 text-[26px] md:text-[32px] leading-none group-hover:text-phosphor-500 transition-colors">{row.label}</div>
                  <div class="font-mono text-[10.5px] tracking-[0.18em] uppercase text-mist-400 mt-2.5 flex items-center gap-3">
                    <span>{row.n} delivered</span>
                    <span class="text-mist-600">·</span>
                    <span class="text-phosphor-500/70 group-hover:text-phosphor-500 transition-colors">read →</span>
                  </div>
                </div>
                <div class="flex items-baseline gap-4 px-2">
                  <div class="hidden md:block w-[180px] lg:w-[280px]">
                    <div class="h-px bg-night-50 relative">
                      <div class="absolute inset-y-0 left-0 bar-grow" style={`background: var(--color-phosphor-500); width: ${(row.pct / 50) * 100}%; height: 1px; animation-delay: ${i * 0.12}s;`}></div>
                    </div>
                  </div>
                  <span class="archi-num text-[36px] md:text-[44px]">{row.pct}<span class="text-mist-400 text-[20px] md:text-[24px]">%</span></span>
                </div>
              </a>
            ))}
          </div>

          <p class="font-mono text-[10.5px] text-mist-400 mt-8 max-w-2xl">
            rate = (fully implemented + partially implemented) / delivered
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CHAPTER INDEX · editorial TOC ───────────────────────────── -->
  <section id="chapters" class="border-b border-night-50 bg-night-100">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 py-16 md:py-20">

      <div class="flex items-baseline justify-between mb-10 md:mb-14 flex-wrap gap-4">
        <div>
          <div class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-phosphor-500 mb-3">// Contents</div>
          <h2 class="font-display italic text-mist-50" style="font-size: clamp(2rem, 4.5vw, 3.5rem);">
            Four chapters.
          </h2>
        </div>
        <span class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-mist-400">read in any order</span>
      </div>

      <ol class="space-y-0">
        {chapters.map((c) => (
          <li class="border-t border-night-50 last:border-b last:border-night-50">
            <a href={c.href} class="group block py-7 md:py-9 hover:bg-night-200 transition-colors -mx-3 md:-mx-6 px-3 md:px-6">
              <div class="grid grid-cols-12 gap-3 md:gap-6 items-baseline">
                <div class="col-span-2 md:col-span-1 archi-num group-hover:text-phosphor-300 transition-colors" style="font-size: clamp(2rem, 3.5vw, 3rem);">{c.num}</div>
                <div class="col-span-10 md:col-span-7">
                  <div class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-mist-400 mb-2 group-hover:text-phosphor-500 transition-colors">
                    {c.eyebrow}
                  </div>
                  <h3 class="font-display tracking-tight leading-[1.05] text-mist-50 group-hover:text-phosphor-500 transition-colors" style="font-size: clamp(1.5rem, 2.6vw, 2.5rem); overflow-wrap: anywhere;">
                    {c.title}
                  </h3>
                  {c.tag && (
                    <span class="inline-block mt-4 font-mono text-[10px] tracking-[0.18em] uppercase text-night-200 bg-phosphor-500 px-2.5 py-1 pulse-mark">
                      {c.tag}
                    </span>
                  )}
                </div>
                <div class="col-span-12 md:col-span-3 md:text-right md:pl-6">
                  <div class="font-display text-mist-50 leading-none" style="font-size: clamp(1.75rem, 2.8vw, 2.5rem);">{c.metric}</div>
                  <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-mist-400 mt-2">{c.label}</div>
                </div>
                <div class="hidden md:flex md:col-span-1 justify-end items-baseline font-mono text-[14px] text-mist-400 group-hover:text-phosphor-500 transition-colors">→</div>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ─── LANGUAGE · poster ─────────────────────────────────────────── -->
  <section class="border-b border-night-50 bg-night-200">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 py-20 md:py-28">

      <div class="grid grid-cols-12 gap-y-10 gap-x-8 items-baseline mb-12 md:mb-16">
        <div class="col-span-12 md:col-span-8">
          <div class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-phosphor-500 mb-4">
            ◆ Implementation rate · by language
          </div>
          <h2 class="font-display leading-[0.98] tracking-tight text-mist-50" style="font-size: clamp(2rem, 4.5vw, 3.5rem); overflow-wrap: anywhere;">
            Two out of three Rust suggestions get a fix.<br/>
            <span class="italic phosphor">One out of three TypeScript ones do.</span>
          </h2>
        </div>
        <div class="col-span-12 md:col-span-4">
          <div class="aside max-w-sm">
            languages with ≥ 200 delivered suggestions and ≥ 5 distinct organizations. compiled, strongly-typed languages cluster at the top.
          </div>
        </div>
      </div>

      <div class="space-y-1.5">
        {langs.map((l) => (
          <div class="data-row group" style="grid-template-columns: 130px 1fr auto;">
            <div class="font-display text-mist-50 text-[18px] md:text-[20px] leading-none px-2 group-hover:text-phosphor-500 transition-colors">{l.name}</div>
            <div class="px-2">
              <div class="h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style={`background: var(--color-phosphor-500); width: ${(l.pct / 65) * 100}%; height: 1px;`}></div>
              </div>
            </div>
            <div class="flex items-baseline gap-3 px-2 tabular-nums">
              <span class="font-mono text-mist-400 text-[10px] hidden md:inline">{l.n.toLocaleString()}</span>
              <span class="font-display phosphor text-[18px] md:text-[20px]">{l.pct}%</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── MODELS · terminal data table ─────────────────────────────── -->
  <section class="border-b border-night-50 bg-night-100">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 py-20 md:py-28">

      <div class="grid grid-cols-12 gap-y-10 gap-x-8 items-baseline mb-12">
        <div class="col-span-12 md:col-span-7">
          <div class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-phosphor-500 mb-4">
            ◆ Chapter 04 preview
          </div>
          <h2 class="font-display leading-[0.98] tracking-tight text-mist-50" style="font-size: clamp(2rem, 4.5vw, 3.5rem); overflow-wrap: anywhere;">
            Kimi K2.5 lands twice as often<br/>
            <span class="italic phosphor">as Claude Sonnet.</span>
          </h2>
        </div>
        <div class="col-span-12 md:col-span-5">
          <p class="text-mist-200 leading-[1.6] text-[14px] md:text-[15px] max-w-md">
            79 teams running 5 providers and 20+ distinct models. The top eight span a 2× implementation-rate gap. The three commercial APIs (Anthropic, Gemini, OpenAI) cluster within 3.4 points of each other in the middle of the pack.
          </p>
        </div>
      </div>

      <div>
        <div class="data-row text-mist-400 font-mono text-[10px] tracking-[0.22em] uppercase" style="grid-template-columns: 1fr 200px 100px; padding: 8px 0;">
          <div class="px-2">model</div>
          <div class="px-2">endpoint</div>
          <div class="px-2 text-right">rate</div>
        </div>
        {modelRows.map((r) => (
          <div class="data-row group" style="grid-template-columns: 1fr 200px 100px;">
            <div class="font-display text-mist-50 text-[16px] md:text-[18px] leading-none px-2 group-hover:text-phosphor-500 transition-colors">{r.model}</div>
            <div class="font-mono text-mist-200 text-[12px] px-2 hidden md:block">{r.endpoint}</div>
            <div class="px-2 text-right archi-num text-[18px] md:text-[22px]">{r.pct}%</div>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <a href="/models/" class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-phosphor-500 hover:text-phosphor-300 transition-colors">
          ↳ full chapter 04 · all 21 models
        </a>
      </div>
    </div>
  </section>

  <!-- ─── CITATION · editorial closer ──────────────────────────────── -->
  <section class="bg-night-200">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 py-20">
      <div class="grid grid-cols-12 gap-y-10 gap-x-8 items-end">
        <div class="col-span-12 md:col-span-6">
          <div class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-mist-200 mb-4">// the work</div>
          <h2 class="font-display italic text-mist-50 leading-[1.05]" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">
            Reuse with attribution.<br/>
            <span class="text-mist-400">Refresh quarterly.</span>
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6">
          <pre class="font-mono text-[12px] leading-relaxed text-mist-50 bg-night-300 border-l-2 border-phosphor-500 p-5 overflow-x-auto">State of AI Code Review (2026-Q2).
Research by Kodus.
https://stateofcodereview.com</pre>
          <div class="mt-5 flex gap-6 flex-wrap font-mono text-[10.5px] tracking-[0.22em] uppercase">
            <a href="/methodology/" class="text-mist-200 hover:text-phosphor-500">↳ Methodology</a>
            <a href="https://github.com/kodustech/stateofcodereview.com" class="text-mist-200 hover:text-phosphor-500">↳ GitHub repo</a>
            <a href="https://creativecommons.org/licenses/by/4.0/" class="text-mist-200 hover:text-phosphor-500">↳ CC BY 4.0</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contextual scripts -->
  <script is:inline>
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Mouse-follow atmospheric glow
    const hero = document.getElementById('hero');
    if (hero && !reducedMotion) {
      hero.addEventListener('pointermove', (e) => {
        const rect = hero.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        hero.style.setProperty('--mx', x + '%');
        hero.style.setProperty('--my', y + '%');
      }, { passive: true });
    }

    // Counter
    function animateCounter(el, target, duration) {
      if (reducedMotion) { el.textContent = String(target); return; }
      const start = performance.now();
      function tick(now) {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(eased * target);
        if (t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
    const counters = document.querySelectorAll('[data-counter]');
    if (counters.length) {
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const target = parseInt(entry.target.dataset.target || '0', 10);
              animateCounter(entry.target, target, 1800);
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.35 });
        counters.forEach((c) => io.observe(c));
      } else {
        counters.forEach((c) => {
          const target = parseInt(c.dataset.target || '0', 10);
          c.textContent = String(target);
        });
      }
    }

    // Live code review demo
    const demo = document.getElementById('code-demo');
    if (demo) {
      const examples = [
        {
          file: 'packages/auth/login.ts:42', lang: 'typescript', cls: 'bug', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 40, t: 'function authenticate(token: string) {' },
            { n: 41, t: '  const user = db.users.find({ token });' },
            { n: 42, t: '  return user.session.id;', state: 'minus' },
            { n: 42, t: '  if (!user) throw new Error("Invalid token");', state: 'plus' },
            { n: 43, t: '  return user.session.id;', state: 'plus' },
            { n: 44, t: '}' },
          ],
          msg: 'Missing null check on user. db.users.find returns null for unknown tokens, and user.session.id will throw at runtime.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: 'bug findings: 33% land like this',
        },
        {
          file: 'internal/sql/repo.go:87', lang: 'go', cls: 'security', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 85, t: 'func GetUser(name string) (*User, error) {' },
            { n: 86, t: '  q := fmt.Sprintf("SELECT * FROM users WHERE name = \'%s\'", name)', state: 'flag' },
            { n: 87, t: '  return db.QueryRow(q).Scan(&u)', state: 'minus' },
            { n: 86, t: '  return db.QueryRow("SELECT * FROM users WHERE name = $1", name).Scan(&u)', state: 'plus' },
            { n: 88, t: '}' },
          ],
          msg: 'SQL injection: name is interpolated directly into the query. Use a parameterized query with $1 binding.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: 'security: 65% acceptance on critical',
        },
        {
          file: 'api/users/handler.py:45', lang: 'python', cls: 'bug', sev: 'high',
          severityColor: 'oklch(86% 0.14 80)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 43, t: 'async def get_certificate(user_id):' },
            { n: 44, t: '  cached = cache.get(user_id)' },
            { n: 45, t: '  if cached: return cached', state: 'flag' },
            { n: 46, t: '  cert = await issue_cert(user_id)' },
            { n: 47, t: '  cache.set(user_id, cert)' },
            { n: 48, t: '  return cert' },
          ],
          msg: 'Race condition: two concurrent requests for the same user will both call issue_cert(). Wrap the cache check + issue in an asyncio.Lock keyed by user_id.',
          stamp: '~ adapted', stampBg: 'oklch(78% 0.18 75 / 0.18)', stampColor: 'var(--color-phosphor-500)',
          meta: 'dev applied a different fix on these lines',
        },
        {
          file: 'src/prompts/system.py:18', lang: 'python', cls: 'security', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 16, t: 'def build_prompt(user_input, request_data):' },
            { n: 17, t: '  return f"""You are a helpful assistant.', state: 'minus' },
            { n: 18, t: '  Request: {request_data}', state: 'minus' },
            { n: 19, t: '  Input: {user_input}"""', state: 'minus' },
            { n: 17, t: '  return SYSTEM + delimit(user_input) + delimit(request_data)', state: 'plus' },
          ],
          msg: 'Prompt injection: user_input concatenated into the system prompt without delimiters. Sanitize and wrap user-controlled strings in dedicated boundaries.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: 'prompt injection · new top-10 in 2026',
        },
      ];

      const fileEl  = document.getElementById('demo-file');
      const langEl  = document.getElementById('demo-lang');
      const sevEl   = document.getElementById('demo-severity');
      const codeEl  = document.getElementById('demo-code');
      const aiEl    = document.getElementById('demo-ai');
      const msgEl   = document.getElementById('demo-msg');
      const classEl = document.getElementById('demo-class');
      const outcEl  = document.getElementById('demo-outcome');
      const stampEl = document.getElementById('demo-stamp');
      const metaEl  = document.getElementById('demo-meta');
      const idxEl   = document.getElementById('demo-counter');

      let idx = 0;
      function typeMessage(text, el, speed) {
        el.textContent = '';
        el.classList.add('typing');
        if (reducedMotion) { el.textContent = text; el.classList.remove('typing'); return; }
        let i = 0;
        (function step() {
          if (i <= text.length) {
            el.textContent = text.slice(0, i);
            i++;
            setTimeout(step, speed);
          } else {
            el.classList.remove('typing');
          }
        })();
      }
      function render(ex) {
        fileEl.textContent  = ex.file;
        langEl.textContent  = ex.lang;
        sevEl.textContent   = ex.sev;
        sevEl.style.background = ex.severityColor;
        sevEl.style.color      = ex.severityText;
        classEl.textContent = ex.cls;
        idxEl.textContent   = `${String(idx + 1).padStart(2, '0')} / ${String(examples.length).padStart(2, '0')}`;

        codeEl.innerHTML = '';
        ex.lines.forEach((ln, i) => {
          const span = document.createElement('span');
          const stateCls = ln.state === 'minus' ? 'line-minus' : ln.state === 'plus' ? 'line-plus' : ln.state === 'flag' ? 'line-flag' : '';
          span.className = `code-line line-num anim-line ${stateCls}`;
          span.setAttribute('data-ln', ln.n);
          span.style.animationDelay = `${i * 0.06}s`;
          const prefix = ln.state === 'minus' ? '- ' : ln.state === 'plus' ? '+ ' : '  ';
          span.textContent = prefix + ln.t;
          codeEl.appendChild(span);
        });
        aiEl.classList.remove('ai-card'); void aiEl.offsetWidth; aiEl.classList.add('ai-card');
        outcEl.classList.remove('stamp-in'); void outcEl.offsetWidth; outcEl.classList.add('stamp-in');
        stampEl.textContent = ex.stamp;
        stampEl.style.background = ex.stampBg;
        stampEl.style.color = ex.stampColor;
        metaEl.textContent = ex.meta;

        const linesDoneAt = ex.lines.length * 60 + 250;
        setTimeout(() => typeMessage(ex.msg, msgEl, 18), linesDoneAt);
      }
      function next() { render(examples[idx % examples.length]); idx++; }
      next();
      if (!reducedMotion) { setInterval(next, 9000); }
    }

    // Live suggestion counter
    const liveSuggestions = document.getElementById('live-suggestions');
    if (liveSuggestions && !reducedMotion) {
      let value = 162262;
      setInterval(() => {
        if (Math.random() > 0.5) {
          value += Math.floor(Math.random() * 3) + 1;
          liveSuggestions.textContent = value.toLocaleString('en-US');
        }
      }, 4200);
    }
  </script>
</Layout>
