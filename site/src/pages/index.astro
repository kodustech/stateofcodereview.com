---
import Layout from '../layouts/Layout.astro';

const chapters = [
  { num: '01', eyebrow: 'Bugs',            title: 'The 10 bugs AI catches most.',          metric: '90,527', metricLabel: 'bug findings',         href: '/bugs/' },
  { num: '02', eyebrow: 'Vulnerabilities', title: 'The 2026 vulnerability landscape.',     metric: '6,552',  metricLabel: 'security findings',    href: '/vulnerabilities/', tag: 'New · prompt injection' },
  { num: '03', eyebrow: 'Cross-file',      title: 'What AI catches that linters cannot.',  metric: '10,992', metricLabel: 'cross-file findings',  href: '/cross-file/' },
  { num: '04', eyebrow: 'Rules',           title: 'What 610 teams codified.',              metric: '7,276',  metricLabel: 'codified rules',       href: '/rules/' },
  { num: '05', eyebrow: 'Models',          title: 'Best LLM: 28%. Worst: 3%.',             metric: '79',     metricLabel: 'BYOK organizations',   href: '/models/' },
];

const langs = [
  { name: 'Rust',       pct: 37.6 },
  { name: 'Go',         pct: 29.1 },
  { name: 'Vue',        pct: 25.2 },
  { name: 'Python',     pct: 20.5 },
  { name: 'TypeScript', pct: 18.5 },
  { name: 'JavaScript', pct: 16.3 },
  { name: 'Ruby',       pct: 15.4 },
  { name: 'PHP',        pct: 13.0 },
  { name: 'Java',       pct: 12.7 },
  { name: 'C#',         pct: 12.7 },
];
---

<Layout
  page="Frontispiece"
  theme="dark"
>

  <!-- ─── HERO ─────────────────────────────────────────────────────── -->
  <section class="atmos gridfield border-b border-night-50 relative overflow-hidden" id="hero">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-20 md:pt-32 pb-24 md:pb-40 relative">

      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-phosphor-500 mb-10 reveal reveal-1">
        // Field report · MMXXVI · Q2
      </div>

      <h1 class="font-display leading-[0.92] tracking-tight text-mist-50 reveal reveal-2 max-w-5xl"
          style="font-size: clamp(2.75rem, 9vw, 8rem);">
        What happens<br/>
        after the AI <span class="italic phosphor phosphor-pulse">comment lands</span>?
      </h1>

      <!-- Big animated stat -->
      <div class="mt-20 md:mt-28 grid grid-cols-12 gap-8 items-end reveal reveal-3">
        <div class="col-span-12 md:col-span-7">
          <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-4">
            Of every 100 delivered AI suggestions
          </div>
          <div class="flex items-baseline gap-5">
            <span
              class="counter font-display phosphor leading-none"
              data-counter
              data-target="33"
              style="font-size: clamp(7rem, 22vw, 17rem); --num: 0; --target: 33;"
            ></span>
            <span class="font-display phosphor leading-none" style="font-size: clamp(3rem, 7vw, 6rem);">%</span>
          </div>
          <div class="font-mono text-[13px] text-mist-400 mt-6 max-w-md leading-relaxed">
            earn a fix. We read the post-PR diff for every single one. No opt-in feedback, no selection bias.
          </div>
        </div>

        <div class="col-span-12 md:col-span-5 md:pl-8 md:border-l border-night-50 md:pb-6">
          <div class="space-y-5">
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-600">Suggestions</span>
              <span class="font-display text-mist-50 text-2xl">112,336</span>
            </div>
            <div class="flex items-baseline justify-between border-t border-night-50 pt-5">
              <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-600">Organizations</span>
              <span class="font-display text-mist-50 text-2xl">456</span>
            </div>
            <div class="flex items-baseline justify-between border-t border-night-50 pt-5">
              <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mist-600">Window</span>
              <span class="font-mono text-mist-50 text-base">Sep '25 → May '26</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Hero CTAs -->
      <div class="mt-16 flex flex-wrap gap-3 reveal reveal-4">
        <a href="#outcome"
           class="font-mono text-[11px] tracking-[0.22em] uppercase bg-phosphor-500 text-night-200 px-6 py-3.5 hover:bg-phosphor-300 transition-colors">
          ↓ See the split
        </a>
        <a href="/bugs/"
           class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-50 border border-mist-600 px-6 py-3.5 hover:border-phosphor-500 hover:text-phosphor-500 transition-colors">
          Chapter 01 →
        </a>
      </div>
    </div>
  </section>

  <!-- ─── OUTCOME SPLIT ────────────────────────────────────────────── -->
  <section id="outcome" class="border-b border-night-50 bg-night-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32">

      <div class="grid grid-cols-12 gap-12 items-start mb-16">
        <div class="col-span-12 md:col-span-6">
          <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-6">
            ◆ The 33%
          </div>
          <h2 class="font-display leading-[0.98] tracking-tight text-mist-50" style="font-size: clamp(2rem, 5vw, 4rem);">
            Half land <span class="italic phosphor">exactly</span> as written.<br/>
            Half get <span class="italic" style="color: var(--color-signal-cyan);">adapted</span> by the dev.
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:pt-4">
          <p class="text-mist-400 leading-[1.7] text-[15px] max-w-md">
            Implementation status comes from the actual post-PR diff. We compared the suggested code against what shipped on those exact lines.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-12 gap-x-12 gap-y-10">
        <div class="col-span-12 md:col-span-6 group">
          <div class="flex items-baseline justify-between mb-4">
            <div>
              <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600">Applied exactly</div>
              <div class="font-display phosphor mt-2" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1;">17%</div>
            </div>
            <div class="font-mono text-xs text-mist-600">~19,107 / 112,336</div>
          </div>
          <div class="h-[2px] bg-night-50 relative overflow-hidden">
            <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-phosphor-500); width: 51%;"></div>
          </div>
          <p class="text-mist-400 text-[13px] mt-4 leading-relaxed">
            Dev pasted or kept the suggested code as-is on the flagged lines.
          </p>
        </div>

        <div class="col-span-12 md:col-span-6 group">
          <div class="flex items-baseline justify-between mb-4">
            <div>
              <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600">Adapted to fit</div>
              <div class="font-display mt-2" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1; color: var(--color-signal-cyan);">16%</div>
            </div>
            <div class="font-mono text-xs text-mist-600">~18,390 / 112,336</div>
          </div>
          <div class="h-[2px] bg-night-50 relative overflow-hidden">
            <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-signal-cyan); width: 49%; animation-delay: 0.25s;"></div>
          </div>
          <p class="text-mist-400 text-[13px] mt-4 leading-relaxed">
            Dev took the idea and rewrote those lines in their own way.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CHAPTERS ─────────────────────────────────────────────────── -->
  <section class="bg-night-100 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32">

      <div class="flex items-baseline justify-between mb-16 flex-wrap gap-4">
        <h2 class="font-display italic text-mist-50" style="font-size: clamp(2rem, 4vw, 3.25rem);">
          Five chapters.
        </h2>
        <span class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600">// 01–05</span>
      </div>

      <div class="grid grid-cols-1 gap-px bg-night-50">
        {chapters.map((c) => (
          <a href={c.href} class="group glow-on-hover relative bg-night-100 border border-night-50 px-6 md:px-10 py-10 block">
            <div class="grid grid-cols-12 gap-6 items-baseline">
              <div class="col-span-2 md:col-span-1 font-mono text-mist-600 text-sm tracking-wider group-hover:text-phosphor-500 transition-colors">
                {c.num}
              </div>
              <div class="col-span-10 md:col-span-6">
                <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-2 group-hover:text-phosphor-500 transition-colors">
                  {c.eyebrow}
                </div>
                <h3 class="font-display tracking-tight leading-[1.05] text-mist-50 group-hover:text-phosphor-500 transition-colors" style="font-size: clamp(1.5rem, 2.4vw, 2.25rem);">
                  {c.title}
                </h3>
                {c.tag && (
                  <span class="inline-block mt-3 font-mono text-[10px] tracking-[0.18em] uppercase text-night-200 bg-phosphor-500 px-2 py-1">
                    {c.tag}
                  </span>
                )}
              </div>
              <div class="col-span-9 md:col-span-4 md:text-right md:pl-6">
                <div class="font-display text-mist-50" style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1;">{c.metric}</div>
                <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-mist-600 mt-1">{c.metricLabel}</div>
              </div>
              <div class="col-span-3 md:col-span-1 text-right font-mono text-mist-600 text-sm group-hover:text-phosphor-500 transition-colors">
                →
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── LANGUAGE STRIP ────────────────────────────────────────────── -->
  <section class="bg-night-200 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32">

      <div class="grid grid-cols-12 gap-10 items-baseline mb-12">
        <div class="col-span-12 md:col-span-8">
          <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-4">
            ◆ Implementation rate · by language
          </div>
          <h2 class="font-display leading-[1.0] tracking-tight text-mist-50" style="font-size: clamp(2rem, 4.5vw, 3.75rem);">
            <span class="phosphor italic">Rust at 37%.</span>
            <span class="text-mist-400">Java at 12.7%.</span>
          </h2>
        </div>
        <div class="col-span-12 md:col-span-4">
          <p class="text-mist-400 leading-[1.7] text-[14px]">
            Compiled and strongly-typed languages cluster at the top. Verbose enterprise and config files at the bottom.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-2">
        {langs.map((l) => (
          <div class="grid grid-cols-12 gap-4 items-center py-2.5">
            <div class="col-span-3 md:col-span-2 font-display text-mist-50 text-[18px]">{l.name}</div>
            <div class="col-span-7 md:col-span-9">
              <div class="relative h-px bg-night-50">
                <div class="absolute inset-y-0 left-0 bar-grow" style={`background: var(--color-phosphor-500); width: ${(l.pct / 40) * 100}%; height: 1px;`}></div>
              </div>
            </div>
            <div class="col-span-2 md:col-span-1 text-right font-mono text-phosphor-500 text-[13px]">{l.pct}%</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── MODEL PROVOCATION ─────────────────────────────────────────── -->
  <section class="bg-night-100 border-b border-night-50 relative overflow-hidden">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32 relative">
      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-8">
        ◆ Chapter 05 preview
      </div>
      <div class="grid grid-cols-12 gap-10 items-baseline">
        <div class="col-span-12 md:col-span-7">
          <h2 class="font-display leading-[0.95] tracking-tight text-mist-50" style="font-size: clamp(2.5rem, 6vw, 5.5rem);">
            The model barely <span class="italic phosphor">matters.</span>
          </h2>
          <p class="text-mist-400 leading-[1.65] text-[16px] mt-8 max-w-xl">
            79 teams running 5 providers and 20+ distinct models. Anthropic, Gemini and OpenAI all land within 4 percentage points of each other. What predicts higher rates is how the team tunes their prompts and review rules — not which API they call.
          </p>
          <a href="/models/" class="font-mono text-[11px] tracking-[0.22em] uppercase text-phosphor-500 hover:text-phosphor-300 mt-10 inline-block">
            Read chapter 05 →
          </a>
        </div>
        <div class="col-span-12 md:col-span-5">
          <div class="space-y-1">
            <div class="grid grid-cols-3 gap-3 items-baseline py-3 border-b border-night-50">
              <span class="font-mono text-[11px] text-mist-600 col-span-1">ANTHROPIC</span>
              <div class="col-span-1 h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-phosphor-500); width: 84%; height: 1px;"></div>
              </div>
              <span class="font-display phosphor text-right">21.2%</span>
            </div>
            <div class="grid grid-cols-3 gap-3 items-baseline py-3 border-b border-night-50">
              <span class="font-mono text-[11px] text-mist-600 col-span-1">GEMINI</span>
              <div class="col-span-1 h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-phosphor-500); width: 82%; height: 1px; animation-delay: 0.1s;"></div>
              </div>
              <span class="font-display phosphor text-right">20.5%</span>
            </div>
            <div class="grid grid-cols-3 gap-3 items-baseline py-3 border-b border-night-50">
              <span class="font-mono text-[11px] text-mist-600 col-span-1">OPENAI</span>
              <div class="col-span-1 h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-phosphor-500); width: 71%; height: 1px; animation-delay: 0.2s;"></div>
              </div>
              <span class="font-display phosphor text-right">17.8%</span>
            </div>
            <div class="grid grid-cols-3 gap-3 items-baseline py-3">
              <span class="font-mono text-[11px] text-mist-600 col-span-1">SELF-HOST</span>
              <div class="col-span-1 h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-mist-400); width: 62%; height: 1px; animation-delay: 0.3s;"></div>
              </div>
              <span class="font-display text-mist-400 text-right">15.4%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CITATION ──────────────────────────────────────────────────── -->
  <section class="bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <div class="grid grid-cols-12 gap-10 items-end">
        <div class="col-span-12 md:col-span-6">
          <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-4">// Cite this</div>
          <h2 class="font-display italic text-mist-50" style="font-size: clamp(1.5rem, 2.5vw, 2rem);">
            Reuse with attribution.
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6">
          <pre class="font-mono text-[12px] leading-relaxed text-mist-200 bg-night-200 border-l-2 border-phosphor-500 p-5 overflow-x-auto">State of AI Code Review (2026-Q2).
Research by Kodus.
https://stateofcodereview.com</pre>
          <div class="mt-5 flex gap-6 flex-wrap font-mono text-[11px] tracking-[0.22em] uppercase">
            <a href="/methodology/" class="text-mist-400 hover:text-phosphor-500">→ Methodology</a>
            <a href="https://github.com/kodustech/stateofcodereview.com" class="text-mist-400 hover:text-phosphor-500">→ GitHub repo</a>
            <a href="https://creativecommons.org/licenses/by/4.0/" class="text-mist-400 hover:text-phosphor-500">→ CC BY 4.0</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contextual scripts: mouse-follow atmospheric glow + counter on view -->
  <script is:inline>
    // Atmospheric mouse-follow glow on hero
    const hero = document.getElementById('hero');
    if (hero && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      hero.addEventListener('pointermove', (e) => {
        const rect = hero.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        hero.style.setProperty('--mx', x + '%');
        hero.style.setProperty('--my', y + '%');
      }, { passive: true });
    }

    // Counter trigger on view
    const counters = document.querySelectorAll('[data-counter]');
    if (counters.length && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-on');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.4 });
      counters.forEach((c) => io.observe(c));
    } else {
      // Fallback: just show the value
      counters.forEach((c) => c.classList.add('is-on'));
    }
  </script>
</Layout>
