---
import Layout from '../layouts/Layout.astro';

const outcomes = [
  { label: 'Fully implemented',     pct: 17.0, color: 'moss'    },
  { label: 'Partially implemented', pct: 16.4, color: 'ochre'   },
  { label: 'Left untouched',        pct: 66.6, color: 'paper'   },
];

const chapters = [
  { num: '01', eyebrow: 'Bugs',            title: 'The 10 bugs AI catches most.',          metric: '90,527', metricLabel: 'bug findings',         href: '/bugs/' },
  { num: '02', eyebrow: 'Vulnerabilities', title: 'The 2026 vulnerability landscape.',     metric: '6,552',  metricLabel: 'security findings',    href: '/vulnerabilities/', tag: 'New class · prompt injection' },
  { num: '03', eyebrow: 'Cross-file',      title: 'What AI catches that linters cannot.',  metric: '10,992', metricLabel: 'cross-file findings',  href: '/cross-file/' },
  { num: '04', eyebrow: 'Rules',           title: 'What 610 teams codified.',              metric: '7,276',  metricLabel: 'codified rules',       href: '/rules/' },
  { num: '05', eyebrow: 'Models',          title: 'Best LLM: 28.6%. Worst: 17.8%.',        metric: '79',     metricLabel: 'BYOK organizations',   href: '/models/' },
];

// Top languages by implementation rate (full only)
const langs = [
  { name: 'Rust',       pct: 37.6 },
  { name: 'Go',         pct: 29.1 },
  { name: 'Vue',        pct: 25.2 },
  { name: 'Python',     pct: 20.5 },
  { name: 'TypeScript', pct: 18.5 },
  { name: 'JavaScript', pct: 16.3 },
  { name: 'Ruby',       pct: 15.4 },
  { name: 'PHP',        pct: 13.0 },
  { name: 'Java',       pct: 12.7 },
  { name: 'C#',         pct: 12.7 },
];

function tier(pct: number): string {
  if (pct >= 25) return 'moss';
  if (pct >= 17) return 'ochre';
  return 'oxblood';
}
function bar(pct: number): string {
  const t = tier(pct);
  return t === 'moss' ? 'bg-moss-500' : t === 'ochre' ? 'bg-ochre-500' : 'bg-oxblood-500';
}
---

<Layout page="Frontispiece">

  <!-- HERO: one claim, one stat, one CTA -->
  <section class="border-b-2 border-ink-900">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-20">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-8">
          <div class="flex items-center gap-3 flex-wrap reveal reveal-1">
            <span class="stamp text-oxblood-500">Field report · MMXXVI Q2</span>
          </div>

          <h1 class="font-display leading-[0.92] tracking-tight text-ink-900 mt-6 reveal reveal-2"
              style="font-size: clamp(3.5rem, 11vw, 9.5rem);">
            1 in 3 AI code reviews<br/>
            <span class="italic text-oxblood-500">earns a fix.</span>
          </h1>

          <p class="text-ink-700 mt-8 max-w-2xl leading-[1.55] text-[19px] reveal reveal-3">
            We measured what happened to 112,336 AI code review suggestions delivered to 456 engineering teams. This is what shipped on those lines after the PR closed.
          </p>

          <div class="mt-10 flex flex-wrap gap-3 reveal reveal-4">
            <a href="#outcomes" class="tracked bg-ink-900 text-paper-50 px-5 py-3 hover:bg-oxblood-500 transition-colors">↓ See the breakdown</a>
          </div>
        </div>

        <aside class="col-span-12 md:col-span-4 reveal reveal-3">
          <div class="border-2 border-ink-900 bg-paper-200 p-6">
            <div class="tracked text-oxblood-500 mb-4">Of every 100 delivered</div>
            <div class="space-y-3">
              <div>
                <div class="flex justify-between items-baseline mb-1">
                  <span class="text-ink-900">Fully implemented</span>
                  <span class="font-mono text-moss-700 text-lg">17</span>
                </div>
                <div class="h-2 bg-paper-300"><div class="h-full bg-moss-500" style="width: 17%"></div></div>
              </div>
              <div>
                <div class="flex justify-between items-baseline mb-1">
                  <span class="text-ink-900">Partially adapted</span>
                  <span class="font-mono text-ochre-700 text-lg">16</span>
                </div>
                <div class="h-2 bg-paper-300"><div class="h-full bg-ochre-500" style="width: 16%"></div></div>
              </div>
              <div>
                <div class="flex justify-between items-baseline mb-1">
                  <span class="text-ink-500">Left untouched</span>
                  <span class="font-mono text-ink-500 text-lg">67</span>
                </div>
                <div class="h-2 bg-paper-300"><div class="h-full bg-ink-300" style="width: 67%"></div></div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- OUTCOMES section -->
  <section id="outcomes" class="dark-section border-b-2 border-ink-900">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32">
      <h2 class="font-display leading-[0.95] tracking-tight text-paper-100 mb-12" style="font-size: clamp(2.5rem, 6.5vw, 5.5rem);">
        Once a comment lands,<br/>
        <span class="italic text-ochre-300">1 in 3 earns a fix.</span>
      </h2>

      <div class="space-y-4 max-w-4xl">
        {outcomes.map((o) => (
          <div class="grid grid-cols-12 gap-4 items-center">
            <div class="col-span-12 md:col-span-4 text-paper-100 font-display text-[22px]">{o.label}</div>
            <div class="col-span-9 md:col-span-6">
              <div class="relative h-12 bg-ink-700/40">
                <div
                  class={`absolute inset-y-0 left-0 bar-grow ${o.color === 'moss' ? 'bg-moss-500' : o.color === 'ochre' ? 'bg-ochre-500' : 'bg-paper-300'}`}
                  style={`width: ${o.pct}%;`}
                ></div>
              </div>
            </div>
            <div class="col-span-3 md:col-span-2 text-right">
              <span class="font-display text-paper-100 text-[32px]">{o.pct}%</span>
            </div>
          </div>
        ))}
      </div>

      <p class="margin-note text-paper-300 mt-10 max-w-2xl">
        Status is read from the post-PR diff, not from opt-in feedback. Every delivered suggestion is counted, including ignored ones.
      </p>
    </div>
  </section>

  <!-- LANGUAGE CHART (simplified — one column, one metric) -->
  <section class="border-b-2 border-ink-900 bg-paper-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24">
      <h2 class="font-display leading-[0.95] tracking-tight text-ink-900 mb-12" style="font-size: clamp(2.25rem, 5.5vw, 4.5rem);">
        <span class="italic text-oxblood-500">Rust at 37%.</span><br/>
        <span class="text-ink-700">Java and C# at 12%.</span>
      </h2>

      <div class="space-y-3 max-w-4xl">
        {langs.map((l) => (
          <div class="grid grid-cols-12 gap-3 items-center">
            <div class="col-span-3 md:col-span-2 font-display text-ink-900 text-[22px]">{l.name}</div>
            <div class="col-span-7 md:col-span-8">
              <div class="relative h-8 bg-paper-300">
                <div class={`absolute inset-y-0 left-0 bar-grow ${bar(l.pct)}`} style={`width: ${(l.pct / 40) * 100}%;`}></div>
              </div>
            </div>
            <div class="col-span-2 text-right">
              <span class="font-display text-ink-900 text-[22px]">{l.pct}%</span>
            </div>
          </div>
        ))}
      </div>

      <p class="margin-note text-ink-500 mt-8 max-w-2xl">
        Percent of delivered suggestions the developer fully implemented. Compiled and strongly-typed languages cluster at the top. Source: query 09.
      </p>
    </div>
  </section>

  <!-- CHAPTERS -->
  <section class="max-w-[1320px] mx-auto px-6 md:px-10 py-24">
    <h2 class="font-display italic text-ink-900 border-b-2 border-ink-900 pb-4 mb-10" style="font-size: clamp(2.25rem, 4.5vw, 3.5rem);">Five chapters.</h2>

    <div class="space-y-0">
      {chapters.map((c) => (
        <a href={c.href} class="block group border-b border-ink-900/20 py-7 hover:bg-paper-200/60 transition-colors">
          <div class="grid grid-cols-12 gap-6 items-baseline">
            <div class="col-span-1 font-display italic text-oxblood-500" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">{c.num}</div>
            <div class="col-span-11 md:col-span-7">
              <div class="tracked text-ink-500 mb-2">{c.eyebrow}</div>
              <h3 class="font-display tracking-tight leading-tight text-ink-900 group-hover:text-oxblood-700 transition-colors" style="font-size: clamp(1.6rem, 2.5vw, 2.25rem);">{c.title}</h3>
              {c.tag && <span class="pill pill-new pulse-mark mt-3 inline-block">{c.tag}</span>}
            </div>
            <div class="col-span-12 md:col-span-3 md:text-right">
              <div class="font-display text-ink-900" style="font-size: clamp(1.5rem, 2.5vw, 2rem);">{c.metric}</div>
              <div class="tracked-xs text-ink-500 mt-1">{c.metricLabel}</div>
            </div>
            <div class="hidden md:block md:col-span-1 text-right tracked text-ink-300 group-hover:text-oxblood-500 transition-colors">→</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CITATION -->
  <section class="max-w-[1320px] mx-auto px-6 md:px-10 py-16 border-t-2 border-ink-900">
    <div class="grid grid-cols-12 gap-8 items-baseline">
      <div class="col-span-12 md:col-span-5">
        <h2 class="font-display italic text-ink-900" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">Cite this.</h2>
      </div>
      <div class="col-span-12 md:col-span-7">
        <p class="font-mono text-sm bg-paper-200 border-l-2 border-oxblood-500 p-4 leading-relaxed">
          State of AI Code Review (2026-Q2).<br/>
          Research by Kodus. https://stateofcodereview.com
        </p>
        <div class="mt-5 flex gap-6 flex-wrap">
          <a href="/methodology/" class="tracked text-ink-500 hover:text-oxblood-500">↳ Methodology</a>
          <a href="https://github.com/kodustech/stateofcodereview.com" class="tracked text-ink-500 hover:text-oxblood-500">↳ GitHub</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
