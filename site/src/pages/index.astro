              </div>
              <div class="col-span-9 md:col-span-4 md:text-right md:pl-6">
                <div class="font-display text-mist-50" style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1;">{c.metric}</div>
                <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-mist-600 mt-1">{c.metricLabel}</div>
              </div>
              <div class="col-span-3 md:col-span-1 text-right font-mono text-mist-600 text-sm group-hover:text-phosphor-500 transition-colors">
                →
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── LANGUAGE STRIP ────────────────────────────────────────────── -->
  <section class="bg-night-200 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32">

      <div class="grid grid-cols-12 gap-10 items-baseline mb-12">
        <div class="col-span-12 md:col-span-8">
          <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-4">
            ◆ Implementation rate · by language
          </div>
          <h2 class="font-display leading-[1.0] tracking-tight text-mist-50" style="font-size: clamp(2rem, 4.5vw, 3.75rem);">
            <span class="phosphor italic">Rust at 37%.</span>
            <span class="text-mist-400">Java at 12.7%.</span>
          </h2>
        </div>
        <div class="col-span-12 md:col-span-4">
          <p class="text-mist-400 leading-[1.7] text-[14px]">
            Compiled and strongly-typed languages cluster at the top. Verbose enterprise and config files at the bottom.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-2">
        {langs.map((l) => (
          <div class="grid grid-cols-12 gap-4 items-center py-2.5">
            <div class="col-span-3 md:col-span-2 font-display text-mist-50 text-[18px]">{l.name}</div>
            <div class="col-span-7 md:col-span-9">
              <div class="relative h-px bg-night-50">
                <div class="absolute inset-y-0 left-0 bar-grow" style={`background: var(--color-phosphor-500); width: ${(l.pct / 40) * 100}%; height: 1px;`}></div>
              </div>
            </div>
            <div class="col-span-2 md:col-span-1 text-right font-mono text-phosphor-500 text-[13px]">{l.pct}%</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── MODEL PROVOCATION ─────────────────────────────────────────── -->
  <section class="bg-night-100 border-b border-night-50 relative overflow-hidden">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-24 md:py-32 relative">
      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-8">
        ◆ Chapter 05 preview
      </div>
      <div class="grid grid-cols-12 gap-10 items-baseline">
        <div class="col-span-12 md:col-span-7">
          <h2 class="font-display leading-[0.95] tracking-tight text-mist-50" style="font-size: clamp(2.5rem, 6vw, 5.5rem);">
            The model barely <span class="italic phosphor">matters.</span>
          </h2>
          <p class="text-mist-400 leading-[1.65] text-[16px] mt-8 max-w-xl">
            79 teams running 5 providers and 20+ distinct models. Anthropic, Gemini and OpenAI all land within 4 percentage points of each other. What predicts higher rates is how the team tunes their prompts and review rules — not which API they call.
          </p>
          <a href="/models/" class="font-mono text-[11px] tracking-[0.22em] uppercase text-phosphor-500 hover:text-phosphor-300 mt-10 inline-block">
            Read chapter 05 →
          </a>
        </div>
        <div class="col-span-12 md:col-span-5">
          <div class="space-y-1">
            <div class="grid grid-cols-3 gap-3 items-baseline py-3 border-b border-night-50">
              <span class="font-mono text-[11px] text-mist-600 col-span-1">ANTHROPIC</span>
              <div class="col-span-1 h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-phosphor-500); width: 84%; height: 1px;"></div>
              </div>
              <span class="font-display phosphor text-right">21.2%</span>
            </div>
            <div class="grid grid-cols-3 gap-3 items-baseline py-3 border-b border-night-50">
              <span class="font-mono text-[11px] text-mist-600 col-span-1">GEMINI</span>
              <div class="col-span-1 h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-phosphor-500); width: 82%; height: 1px; animation-delay: 0.1s;"></div>
              </div>
              <span class="font-display phosphor text-right">20.5%</span>
            </div>
            <div class="grid grid-cols-3 gap-3 items-baseline py-3 border-b border-night-50">
              <span class="font-mono text-[11px] text-mist-600 col-span-1">OPENAI</span>
              <div class="col-span-1 h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-phosphor-500); width: 71%; height: 1px; animation-delay: 0.2s;"></div>
              </div>
              <span class="font-display phosphor text-right">17.8%</span>
            </div>
            <div class="grid grid-cols-3 gap-3 items-baseline py-3">
              <span class="font-mono text-[11px] text-mist-600 col-span-1">SELF-HOST</span>
              <div class="col-span-1 h-px bg-night-50 relative">
                <div class="absolute inset-y-0 left-0 bar-grow" style="background: var(--color-mist-400); width: 62%; height: 1px; animation-delay: 0.3s;"></div>
              </div>
              <span class="font-display text-mist-400 text-right">15.4%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CITATION ──────────────────────────────────────────────────── -->
  <section class="bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <div class="grid grid-cols-12 gap-10 items-end">
        <div class="col-span-12 md:col-span-6">
          <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-mist-600 mb-4">// Cite this</div>
          <h2 class="font-display italic text-mist-50" style="font-size: clamp(1.5rem, 2.5vw, 2rem);">
            Reuse with attribution.
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6">
          <pre class="font-mono text-[12px] leading-relaxed text-mist-200 bg-night-200 border-l-2 border-phosphor-500 p-5 overflow-x-auto">State of AI Code Review (2026-Q2).
Research by Kodus.
https://stateofcodereview.com</pre>
          <div class="mt-5 flex gap-6 flex-wrap font-mono text-[11px] tracking-[0.22em] uppercase">
            <a href="/methodology/" class="text-mist-400 hover:text-phosphor-500">→ Methodology</a>
            <a href="https://github.com/kodustech/stateofcodereview.com" class="text-mist-400 hover:text-phosphor-500">→ GitHub repo</a>
            <a href="https://creativecommons.org/licenses/by/4.0/" class="text-mist-400 hover:text-phosphor-500">→ CC BY 4.0</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contextual scripts: mouse glow · counter · live ticker · suggestion tick -->
  <script is:inline>
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ─── Mouse-follow atmospheric glow on hero ──────────────────────────
    const hero = document.getElementById('hero');
    if (hero && !reducedMotion) {
      hero.addEventListener('pointermove', (e) => {
        const rect = hero.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        hero.style.setProperty('--mx', x + '%');
        hero.style.setProperty('--my', y + '%');
      }, { passive: true });
    }

    // ─── Counter animation via rAF (ease-out cubic) ────────────────────
    function animateCounter(el, target, duration) {
      if (reducedMotion) { el.textContent = String(target); return; }
      const start = performance.now();
      function tick(now) {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(eased * target);
        if (t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const counters = document.querySelectorAll('[data-counter]');
    if (counters.length) {
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const target = parseInt(entry.target.dataset.target || '0', 10);
              animateCounter(entry.target, target, 1600);
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.35 });
        counters.forEach((c) => io.observe(c));
      } else {
        counters.forEach((c) => {
          const target = parseInt(c.dataset.target || '0', 10);
          c.textContent = String(target);
        });
      }
    }

    // ─── Live code review demo · rotates through real-flavor examples ──
    const demo = document.getElementById('code-demo');
    if (demo) {
      const examples = [
        {
          file: 'packages/auth/login.ts:42', lang: 'typescript', cls: 'bug', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 40, t: 'function authenticate(token: string) {' },
            { n: 41, t: '  const user = db.users.find({ token });' },
            { n: 42, t: '  return user.session.id;', state: 'minus' },
            { n: 42, t: '  if (!user) throw new Error("Invalid token");', state: 'plus' },
            { n: 43, t: '  return user.session.id;', state: 'plus' },
            { n: 44, t: '}' },
          ],
          msg: 'Missing null check on user. db.users.find returns null for unknown tokens, and user.session.id will throw at runtime.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: '17% of suggestions land like this',
        },
        {
          file: 'internal/sql/repo.go:87', lang: 'go', cls: 'security', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 85, t: 'func GetUser(name string) (*User, error) {' },
            { n: 86, t: '  q := fmt.Sprintf("SELECT * FROM users WHERE name = \'%s\'", name)', state: 'flag' },
            { n: 87, t: '  return db.QueryRow(q).Scan(&u)', state: 'minus' },
            { n: 86, t: '  return db.QueryRow("SELECT * FROM users WHERE name = $1", name).Scan(&u)', state: 'plus' },
            { n: 88, t: '}' },
          ],
          msg: 'SQL injection: name is interpolated directly into the query. Use a parameterized query with $1 binding.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: 'security findings: 65% acceptance on critical',
        },
        {
          file: 'api/users/handler.py:45', lang: 'python', cls: 'bug', sev: 'high',
          severityColor: 'oklch(86% 0.14 80)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 43, t: 'async def get_certificate(user_id):' },
            { n: 44, t: '  cached = cache.get(user_id)' },
            { n: 45, t: '  if cached: return cached', state: 'flag' },
            { n: 46, t: '  cert = await issue_cert(user_id)' },
            { n: 47, t: '  cache.set(user_id, cert)' },
            { n: 48, t: '  return cert' },
          ],
          msg: 'Race condition: two concurrent requests for the same user will both call issue_cert(). Wrap the cache check + issue in an asyncio.Lock keyed by user_id.',
          stamp: '~ adapted', stampBg: 'oklch(78% 0.18 75 / 0.18)', stampColor: 'var(--color-phosphor-500)',
          meta: 'dev applied a different fix on these lines',
        },
        {
          file: 'src/prompts/system.py:18', lang: 'python', cls: 'security', sev: 'critical',
          severityColor: 'var(--color-phosphor-500)', severityText: 'var(--color-night-200)',
          lines: [
            { n: 16, t: 'def build_prompt(user_input, request_data):' },
            { n: 17, t: '  return f"""You are a helpful assistant.', state: 'minus' },
            { n: 18, t: '  Request: {request_data}', state: 'minus' },
            { n: 19, t: '  Input: {user_input}"""', state: 'minus' },
            { n: 17, t: '  return SYSTEM + delimit(user_input) + delimit(request_data)', state: 'plus' },
          ],
          msg: 'Prompt injection: user_input concatenated into the system prompt without delimiters. Sanitize and wrap user-controlled strings in dedicated boundaries.',
          stamp: '✓ applied', stampBg: 'oklch(45% 0.13 145 / 0.25)', stampColor: 'oklch(85% 0.15 145)',
          meta: 'prompt injection · new top-10 class in 2026',
        },
      ];

      const fileEl  = document.getElementById('demo-file');
      const langEl  = document.getElementById('demo-lang');
      const sevEl   = document.getElementById('demo-severity');
      const codeEl  = document.getElementById('demo-code');
      const aiEl    = document.getElementById('demo-ai');
      const msgEl   = document.getElementById('demo-msg');
      const classEl = document.getElementById('demo-class');
      const outcEl  = document.getElementById('demo-outcome');
      const stampEl = document.getElementById('demo-stamp');
      const metaEl  = document.getElementById('demo-meta');
      const idxEl   = document.getElementById('demo-counter');

      let idx = 0;

      function typeMessage(text, el, speed = 18, done) {
        el.textContent = '';
        el.classList.add('typing');
        if (reducedMotion) { el.textContent = text; el.classList.remove('typing'); if (done) done(); return; }
        let i = 0;
        (function step() {
          if (i <= text.length) {
            el.textContent = text.slice(0, i);
            i++;
            setTimeout(step, speed);
          } else {
            el.classList.remove('typing');
            if (done) done();
          }
        })();
      }

      function render(ex) {
        fileEl.textContent  = ex.file;
        langEl.textContent  = ex.lang;
        sevEl.textContent   = ex.sev;
        sevEl.style.background = ex.severityColor;
        sevEl.style.color      = ex.severityText;
        classEl.textContent = ex.cls;
        idxEl.textContent   = `${String(idx + 1).padStart(2, '0')} / ${String(examples.length).padStart(2, '0')}`;

        // Code lines with stagger
        codeEl.innerHTML = '';
        ex.lines.forEach((ln, i) => {
          const span = document.createElement('span');
          const stateCls = ln.state === 'minus' ? 'line-minus' : ln.state === 'plus' ? 'line-plus' : ln.state === 'flag' ? 'line-flag' : '';
          span.className = `code-line line-num anim-line ${stateCls}`;
          span.setAttribute('data-ln', ln.n);
          span.style.animationDelay = `${i * 0.06}s`;
          const prefix = ln.state === 'minus' ? '- ' : ln.state === 'plus' ? '+ ' : '  ';
          span.textContent = prefix + ln.t;
          codeEl.appendChild(span);
        });

        // AI card replays animation
        aiEl.classList.remove('ai-card');
        void aiEl.offsetWidth;
        aiEl.classList.add('ai-card');

        // Outcome stamp
        outcEl.classList.remove('stamp-in');
        void outcEl.offsetWidth;
        outcEl.classList.add('stamp-in');
        stampEl.textContent       = ex.stamp;
        stampEl.style.background  = ex.stampBg;
        stampEl.style.color       = ex.stampColor;
        metaEl.textContent        = ex.meta;

        // Type the AI message after lines have settled
        const linesDoneAt = ex.lines.length * 60 + 200;
        setTimeout(() => typeMessage(ex.msg, msgEl, 16), linesDoneAt);
      }

      function next() {
        render(examples[idx % examples.length]);
        idx++;
      }
      next();
      if (!reducedMotion) {
        setInterval(next, 7800);
      }
    }

    // ─── Live suggestion counter · subtle real-time feel ─────────────────
    const liveSuggestions = document.getElementById('live-suggestions');
    if (liveSuggestions && !reducedMotion) {
      let value = 112336;
      setInterval(() => {
        // increment by 1-3 every ~4-9 seconds
        if (Math.random() > 0.5) {
          value += Math.floor(Math.random() * 3) + 1;
          liveSuggestions.textContent = value.toLocaleString('en-US');
        }
      }, 4200);
    }
  </script>
</Layout>
