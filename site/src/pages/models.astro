---
import Layout from '../layouts/Layout.astro';

const rows = [
  { model: 'Kimi K2.5 (NVFP4)',         endpoint: 'Synthetic.new',     pct: 46.2 },
  { model: 'Kimi K2.5',                 endpoint: 'OpenRouter',        pct: 46.2 },
  { model: 'GPT-5.2 Codex',             endpoint: 'OpenAI direct',     pct: 29.3 },
  { model: 'Claude Opus 4.5',           endpoint: 'Anthropic direct',  pct: 27.2 },
  { model: 'KAT Coder Pro',             endpoint: 'OpenRouter',        pct: 24.8 },
  { model: 'Gemini 2.5 Flash',          endpoint: 'Google direct',     pct: 24.2 },
  { model: 'Claude Sonnet 4.5',         endpoint: 'Anthropic direct',  pct: 22.9 },
  { model: 'Gemini 3 Flash Preview',    endpoint: 'Google direct',     pct: 21.7 },
  { model: 'Gemini 3 Pro Preview',      endpoint: 'Google direct',     pct: 19.8 },
  { model: 'GPT-5.3 Codex',             endpoint: 'OpenAI direct',     pct: 17.9 },
  { model: 'Gemini 2.5 Pro',            endpoint: 'Google direct',     pct: 16.9 },
  { model: 'Claude Haiku 4.5',          endpoint: 'Azure AI Foundry',  pct: 15.7 },
  { model: 'GPT-5.2',                   endpoint: 'OpenAI direct',     pct: 15.5 },
  { model: 'Devstral Small 2 24B',      endpoint: 'Self-hosted',       pct: 15.1 },
  { model: 'Claude Haiku 4.5',          endpoint: 'Anthropic direct',  pct: 14.7 },
  { model: 'GLM 4.7',                   endpoint: 'Z.AI direct',       pct: 14.3 },
  { model: 'DeepSeek v3.2',             endpoint: 'OpenRouter',        pct: 11.5 },
  { model: 'Claude Sonnet 4.6',         endpoint: 'Anthropic direct',  pct:  8.3 },
  { model: 'GPT-5',                     endpoint: 'OpenAI direct',     pct:  6.0 },
  { model: 'GLM 4.7 Flash',             endpoint: 'OpenRouter',        pct:  5.0 },
  { model: 'MiniMax M2.5',              endpoint: 'MiniMax direct',    pct:  3.0 },
];

const tone = (pct: number) => {
  if (pct >= 25) return 'var(--color-phosphor-500)';
  if (pct >= 18) return 'var(--color-phosphor-300)';
  return 'oklch(60% 0.12 25)';
};
---

<Layout
  title="The model comparison · State of AI Code Review"
  description="Implementation rate by LLM model and endpoint. 79 BYOK engineering teams running 20+ models across Anthropic, OpenAI, Google, OpenRouter, Synthetic.new, Z.AI, MiniMax, and self-hosted."
  runningHead="§ 04 Models"
  page="Plate IV"
  theme="dark"
>

  <!-- HERO -->
  <section class="border-b border-night-50 bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-16">
      <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-5 reveal reveal-1">
        ◆ Chapter § 04 · Models
      </div>
      <h1 class="font-display leading-[0.95] tracking-tight text-mist-50 reveal reveal-2 max-w-5xl" style="font-size: clamp(2.5rem, 6vw, 5rem);">
        <span class="italic phosphor">Kimi K2.5 leads at 46%.</span><br/>
        MiniMax M2.5 trails at 3%.
      </h1>
      <p class="text-mist-200 mt-8 max-w-2xl leading-[1.55] text-[17px] reveal reveal-3">
        79 engineering teams running 21 different model-and-endpoint combinations. The spread between the top and the bottom is 15×. The big three commercial APIs (Anthropic, Gemini, OpenAI) cluster in the middle.
      </p>
    </div>
  </section>

  <!-- MAIN CHART -->
  <section class="border-b border-night-50 bg-night-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20 md:py-24">
      <h2 class="font-display tracking-tight leading-[0.95] text-mist-50 mb-12" style="font-size: clamp(2rem, 4.5vw, 3.25rem);">
        Implementation rate <span class="italic phosphor">by model.</span>
      </h2>

      <div class="space-y-2.5">
        {rows.map((r) => (
          <div class="grid grid-cols-12 gap-4 items-center py-1">
            <div class="col-span-12 md:col-span-4">
              <div class="text-mist-50 font-display text-[19px] leading-tight">{r.model}</div>
              <div class="font-mono text-[11px] text-mist-400 mt-0.5">{r.endpoint}</div>
            </div>
            <div class="col-span-9 md:col-span-6">
              <div class="relative h-9 bg-night-100">
                <div class="absolute inset-y-0 left-0 bar-grow" style={`background: ${tone(r.pct)}; width: ${(r.pct / 50) * 100}%;`}></div>
              </div>
            </div>
            <div class="col-span-3 md:col-span-2 text-right">
              <span class="font-display text-mist-50 text-[24px]">{r.pct}%</span>
            </div>
          </div>
        ))}
      </div>

      <p class="font-mono text-[11px] text-mist-400 mt-10 max-w-3xl">
        Percent of delivered suggestions the developer fully implemented. Bar scales 0–50%. Each row is one model running on one endpoint. Source: query 11.
      </p>
    </div>
  </section>

  <!-- COMMENTARY -->
  <section class="bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <div class="grid grid-cols-12 gap-8">
        <div class="col-span-12 md:col-span-4">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500">What this means</div>
        </div>
        <div class="col-span-12 md:col-span-8">
          <p class="font-display italic text-mist-50 leading-[1.2]" style="font-size: clamp(1.6rem, 3vw, 2.25rem);">
            Same model. Different endpoint. Same number.
          </p>
          <p class="text-mist-200 leading-[1.7] mt-5 max-w-prose">
            Kimi K2.5 at the top hits 46% whether served through OpenRouter or as the NVFP4 quantized build on Synthetic.new. The endpoint is plumbing. What carries the result is the model and the prompt around it. Frontier models from Anthropic, Google, and OpenAI cluster in a tight band between 17% and 23%. Smaller specialist coder models (GPT-5.2 Codex, KAT Coder Pro) edge ahead of their general-purpose siblings.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SCALE LEGEND -->
  <section class="bg-night-200 border-t border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-10">
      <div class="flex flex-wrap items-center justify-center gap-6 font-mono text-[11px] text-mist-200">
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4" style="background: var(--color-phosphor-500);"></span> ≥ 25%</span>
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4" style="background: var(--color-phosphor-300);"></span> 18–25%</span>
        <span class="flex items-center gap-2"><span class="inline-block w-4 h-4" style="background: oklch(60% 0.12 25);"></span> &lt; 18%</span>
        <span class="text-mist-600">·</span>
        <span class="tracking-[0.22em] uppercase">Source · Query 11 · GitHub</span>
      </div>
    </div>
  </section>
</Layout>
