---
import Layout from '../layouts/Layout.astro';

// Sorted by implementation rate (desc) — the actual question this chart answers.
const providers = [
  { label: 'OpenAI-compatible', pct: 28.6, n: 2125, orgs: 11 },
  { label: 'OpenRouter',        pct: 22.4, n: 2750, orgs: 10 },
  { label: 'Anthropic',         pct: 21.2, n: 2316, orgs: 15 },
  { label: 'Google Gemini',     pct: 20.5, n: 7294, orgs: 24 },
  { label: 'OpenAI',            pct: 17.8, n: 2696, orgs: 19 },
];

const models = [
  { model: 'gpt-5.2-codex',           provider: 'openai',           pct: 29.3, n: 618,  orgs: 4 },
  { model: 'gemini-2.5-flash',        provider: 'google_gemini',    pct: 24.2, n: 372,  orgs: 2 },
  { model: 'claude-sonnet-4-5',       provider: 'anthropic',        pct: 22.9, n: 1784, orgs: 6 },
  { model: 'gemini-3-flash-preview',  provider: 'google_gemini',    pct: 21.7, n: 3620, orgs: 6 },
  { model: 'gemini-3-pro-preview',    provider: 'google_gemini',    pct: 19.8, n: 2048, orgs: 4 },
  { model: 'gemini-2.5-pro',          provider: 'google_gemini',    pct: 16.9, n: 1247, orgs: 4 },
  { model: 'gpt-5.2',                 provider: 'openai',           pct: 15.5, n: 619,  orgs: 2 },
  { model: 'claude-sonnet-4-6',       provider: 'anthropic',        pct:  8.3, n: 169,  orgs: 2 },
];

// Helper for color tier (sorted from best to worst)
function tier(pct: number): string {
  if (pct >= 25) return 'moss';
  if (pct >= 18) return 'ochre';
  return 'oxblood';
}
function barClass(pct: number): string {
  const t = tier(pct);
  return t === 'moss' ? 'bg-moss-500' : t === 'ochre' ? 'bg-ochre-500' : 'bg-oxblood-500';
}
---

<Layout
  title="The model comparison · State of AI Code Review"
  description="79 BYOK engineering teams. 5 LLM providers. Implementation rate ranges from 18% to 29%, depending on the provider."
  runningHead="§ 05 Models"
  page="Plate V"
>

  <!-- HERO -->
  <section class="border-b-2 border-ink-900">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-16 md:pt-20 pb-16">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-2">
          <div class="font-display italic text-oxblood-500 leading-[0.85]" style="font-size: clamp(6rem, 12vw, 11rem);">V</div>
          <div class="tracked text-ink-500 mt-2">Plate V</div>
        </div>
        <div class="col-span-12 md:col-span-10">
          <div class="stamp text-oxblood-500">Chapter § 05 · Models</div>
          <h1 class="font-display leading-[0.95] tracking-tight text-ink-900 mt-5" style="font-size: clamp(2.75rem, 6.5vw, 5.5rem);">
            Best LLM provider:<br/>
            <span class="italic text-oxblood-500">28.6% implementation.</span><br/>
            Worst: <span class="italic">17.8%.</span>
          </h1>
          <p class="text-ink-700 mt-8 max-w-2xl leading-[1.6] text-[18px]">
            79 engineering teams chose their own LLM. We measured how often the developer kept the suggestion. The gap between providers is real but narrower than the marketing suggests.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROVIDER CHART -->
  <section class="dark-section border-b-2 border-ink-900">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <h2 class="font-display tracking-tight leading-[0.95] text-paper-100 mb-12" style="font-size: clamp(2rem, 4.5vw, 3.25rem);">
        Implementation rate <span class="italic text-ochre-300">by provider.</span>
      </h2>

      <div class="space-y-5">
        {providers.map((p) => (
          <div class="grid grid-cols-12 gap-4 items-center">
            <div class="col-span-12 md:col-span-3 text-paper-100 font-display text-[22px]">{p.label}</div>
            <div class="col-span-9 md:col-span-7">
              <div class="relative h-12 bg-ink-700/40">
                <div
                  class={`absolute inset-y-0 left-0 bar-grow ${barClass(p.pct)}`}
                  style={`width: ${(p.pct / 30) * 100}%;`}
                ></div>
              </div>
            </div>
            <div class="col-span-3 md:col-span-2 text-right">
              <span class="font-display text-paper-100 text-[28px] md:text-[32px]">{p.pct}%</span>
            </div>
          </div>
        ))}
      </div>

      <p class="margin-note text-paper-300 mt-8">Percent of delivered suggestions the developer fully implemented. Bar scales 0–30%. Source: query 10.</p>
    </div>
  </section>

  <!-- COMMENTARY -->
  <section class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
    <div class="grid grid-cols-12 gap-8">
      <div class="col-span-12 md:col-span-4">
        <div class="tracked text-oxblood-500">What this means</div>
      </div>
      <div class="col-span-12 md:col-span-8">
        <p class="font-display italic text-ink-900 leading-[1.2]" style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);">
          Self-hosted and Groq-style inference leads. Big-name commercial APIs cluster a step behind.
        </p>
        <p class="text-ink-700 leading-[1.7] mt-5 max-w-prose">
          The gap is not "open beats closed". Several openai-compatible orgs run frontier closed-source models behind Azure or Groq. The signal is that teams investing in their own inference stack tend to also tune their prompts and rules more carefully. Confounders are real. The number is real too.
        </p>
      </div>
    </div>
  </section>

  <!-- MODEL CHART -->
  <section class="border-y-2 border-ink-900 bg-paper-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <div class="flex items-baseline justify-between border-b-2 border-ink-900 pb-3 mb-10 flex-wrap gap-2">
        <h2 class="font-display italic text-ink-900" style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);">By model.</h2>
        <span class="tracked text-ink-500">Multi-org models · 80+ delivered · sorted by implementation rate</span>
      </div>

      <div class="space-y-3">
        {models.map((m) => (
          <div class="grid grid-cols-12 gap-3 items-center">
            <div class="col-span-12 md:col-span-4 font-display text-ink-900 text-[18px]">{m.model}</div>
            <div class="col-span-9 md:col-span-6">
              <div class="relative h-9 bg-paper-300">
                <div
                  class={`absolute inset-y-0 left-0 bar-grow ${barClass(m.pct)}`}
                  style={`width: ${(m.pct / 30) * 100}%;`}
                ></div>
              </div>
            </div>
            <div class="col-span-3 md:col-span-2 text-right">
              <span class="font-display text-ink-900 text-[24px]">{m.pct}%</span>
            </div>
          </div>
        ))}
      </div>

      <p class="margin-note text-ink-500 mt-8">Bar scales 0–30%. Single-org models excluded to avoid sample-size skew (see full table on GitHub). Source: query 11.</p>
    </div>
  </section>

  <!-- SCALE LEGEND -->
  <section class="max-w-[1320px] mx-auto px-6 md:px-10 py-12">
    <div class="flex flex-wrap items-center justify-center gap-6 text-[12px] text-ink-500">
      <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-moss-500"></span> ≥ 25%</span>
      <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-ochre-500"></span> 18–25%</span>
      <span class="flex items-center gap-2"><span class="inline-block w-4 h-4 bg-oxblood-500"></span> &lt; 18%</span>
    </div>
  </section>
</Layout>
