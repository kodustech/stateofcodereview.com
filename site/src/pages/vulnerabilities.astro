---
import Layout from '../layouts/Layout.astro';

const vulns = [
  {
    n: '01', anim: 'anim-sql', severity: 'critical',
    title: 'SQL injection',
    description: "Still the most common class in 2026. User input concatenated straight into SQL strings.",
    sample: "Query built with `fmt.Sprintf(\"... WHERE name = '%s'\", name)`. Switch to parameterized queries with `$1` bindings.",
  },
  {
    n: '02', anim: 'anim-traverse', severity: 'critical',
    title: 'Path traversal',
    description: "Unsanitized URL parameters used to construct file paths.",
    sample: "`resolvePath` accepts absolute paths and `../` segments, escaping the intended sandbox directory and reaching anything readable by the process.",
  },
  {
    n: '03', anim: 'anim-noauth', severity: 'critical',
    title: 'Missing authorization',
    description: "Endpoints that lost their auth dependency during a refactor.",
    sample: "Auth dependencies removed from two routers in a refactor. Endpoints that required `require_scopes(...)` are now open to any authenticated user.",
  },
  {
    n: '04', anim: 'anim-xss', severity: 'high',
    title: 'XSS via unescaped attributes',
    description: "User-controlled values written into HTML attributes without escaping.",
    sample: "Tooltip HTML built by concatenating `data-` attribute values into a `title` attribute. Any record field with a quote breaks out of the attribute.",
  },
  {
    n: '05', anim: 'anim-ssrf', severity: 'high',
    title: 'SSRF',
    description: "URL parameters fed straight into outbound HTTP requests.",
    sample: "User-controlled URL passed into `axios.get(link)` with no allowlist or scheme check. Reaches internal services and cloud metadata endpoints.",
  },
  {
    n: '06', anim: 'anim-hardsecret', severity: 'critical',
    title: 'Hardcoded secrets in source',
    description: "Tokens, API keys, and access credentials committed alongside code.",
    sample: "Service access ID and secret committed as string literals. Once in git history, they're permanently exposed even after rotation.",
  },
  {
    n: '07', anim: 'anim-redirect', severity: 'medium',
    title: 'Open redirect',
    description: "Redirect helpers that block obvious schemes but miss protocol-relative URLs.",
    sample: "`safeReturnToPath` blocks `http://` and `javascript:` but allows `//evil.com`, which browsers resolve as a cross-origin redirect.",
  },
  {
    n: '08', anim: 'anim-logleak', severity: 'high',
    title: 'Sensitive data in logs',
    description: "Raw error objects, internal IDs, or full payloads logged for debugging and never sanitized.",
    sample: "Error message includes the internal workspace ID when a record is found but not owned by the caller. Enables existence-checking through 403 vs 404.",
  },
  {
    n: '09', anim: 'anim-promptinj', severity: 'critical', isNew: true,
    title: 'Prompt injection',
    description: "System prompts that concatenate user-controlled strings without delimiters.",
    sample: "User input concatenated directly into the system prompt with no delimiters. A crafted message can override the assistant's instructions.",
  },
  {
    n: '10', anim: 'anim-defcred', severity: 'high',
    title: 'Default credentials',
    description: "Services deployed with well-known default usernames and passwords.",
    sample: "Message broker deployed with the default `guest / guest` credentials. The guest user is intended for local development only.",
  },
  {
    n: '11', anim: 'anim-cmdinj', severity: 'critical',
    title: 'Command injection',
    description: "User input passed unsanitized into shell commands.",
    sample: "`baseBranch` interpolated into a shell command. Any user who can set the branch name (PR title, webhook payload) can execute arbitrary shell.",
  },
  {
    n: '12', anim: 'anim-origin', severity: 'high',
    title: 'PostMessage origin not validated',
    description: "Window message listeners that process events from any origin.",
    sample: "`window.addEventListener('message', ...)` handler with no `event.origin` check. Any page that opens our iframe can call our handler.",
  },
];

const sevPillStyle = (sev: string) => {
  if (sev === 'critical') return 'background: var(--color-phosphor-500); color: var(--color-night-200);';
  if (sev === 'high')     return 'background: var(--color-phosphor-300); color: var(--color-night-200);';
  return 'background: oklch(35% 0.01 250); color: var(--color-mist-200);';
};
---

<Layout
  title="The 2026 vulnerability landscape · State of AI Code Review"
  description="The top security vulnerability classes AI code review caught on production pull requests in 2026. SQL injection still #1. Prompt injection enters the top 10."
  runningHead="§ 02 Vulnerabilities"
  page="Plate II"
  theme="dark"
>

  <!-- HERO -->
  <section class="border-b border-night-50 bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-16">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-9">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-5 reveal reveal-1">
            ◆ Chapter § 02 · Vulnerabilities
          </div>
          <h1 class="font-display leading-[0.95] tracking-tight text-mist-50 reveal reveal-2" style="font-size: clamp(2.5rem, 6.5vw, 5.5rem); overflow-wrap: anywhere;">
            The 2026 vulnerability <span class="italic phosphor">landscape.</span>
          </h1>
        </div>
        <aside class="col-span-12 md:col-span-3 md:pt-4 reveal reveal-3">
          <div class="border border-night-50 bg-night-200 p-5">
            <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-4">At a glance</div>
            <ul class="space-y-3 text-mist-50">
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2">
                <span class="text-[13px] text-mist-200">Security findings</span>
                <span class="font-mono text-[13px]">6,552</span>
              </li>
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2">
                <span class="text-[13px] text-mist-200">Implemented or adapted</span>
                <span class="font-mono text-[13px] phosphor">28.8%</span>
              </li>
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2">
                <span class="text-[13px] text-mist-200">Classes in top 10</span>
                <span class="font-mono text-[13px]">12</span>
              </li>
              <li class="flex items-baseline justify-between">
                <span class="text-[13px] text-mist-200">New in 2026</span>
                <span class="font-mono text-[13px] phosphor">1</span>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- PROMPT INJECTION HIGHLIGHT -->
  <section class="border-b border-night-50 bg-night-200 relative overflow-hidden">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20 relative">
      <div class="grid grid-cols-12 gap-10 items-center">
        <div class="col-span-12 md:col-span-7">
          <div class="flex items-center gap-3 mb-5">
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase px-2 py-1 pulse-mark" style="background: var(--color-night-300); color: var(--color-phosphor-500); border: 1px solid var(--color-phosphor-500);">new class · 2026</span>
            <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-1" style={sevPillStyle('critical')}>critical</span>
          </div>
          <h2 class="font-display tracking-tight leading-[0.95] text-mist-50" style="font-size: clamp(2.5rem, 6vw, 5rem);">
            <span class="italic phosphor">Prompt injection</span><br/>enters the top 10.
          </h2>
          <p class="text-mist-200 leading-[1.65] text-[16px] mt-6 max-w-xl">
            User-controlled strings concatenated into system prompts. Structurally similar to SQL injection from twenty years ago, freshly relevant as more production code paths route through LLMs. Expect this class to rise in subsequent snapshots.
          </p>
        </div>
        <div class="col-span-12 md:col-span-5">
          <div class="border border-phosphor-500/40 bg-night-300 p-6">
            <div class="font-mono text-[10px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-3">▌ sample finding</div>
            <p class="text-mist-200 leading-[1.7] text-[13px]">
              User input concatenated directly into the system prompt with no delimiters. A crafted message can override the assistant's instructions.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VULN GRID -->
  <section class="bg-night-100 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-16">
      <div class="flex flex-wrap items-center gap-6 font-mono text-[11px] text-mist-400 mb-8">
        <span class="font-medium tracking-[0.22em] uppercase text-mist-200">Severity</span>
        <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" style={sevPillStyle('critical')}>critical</span>
        <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" style={sevPillStyle('high')}>high</span>
        <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" style={sevPillStyle('medium')}>medium</span>
        <span class="ml-auto text-mist-400">Excerpts paraphrased. Pattern preserved.</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {vulns.map((v) => (
          <article class={`glow-on-hover border ${v.isNew ? 'border-phosphor-500/60' : 'border-night-50'} bg-night-200 p-6 relative`}>
            {v.isNew && (
              <div class="absolute -top-3 -right-3">
                <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-1 pulse-mark" style="background: var(--color-phosphor-500); color: var(--color-night-200);">NEW · 2026</span>
              </div>
            )}
            <div class="flex items-start justify-between gap-4 mb-4">
              <div class="flex items-center gap-4">
                <span class="archi-num leading-none" style="font-size: 2.25rem;">{v.n}</span>
                <div class={`vuln-icon ${v.anim}`}>
                  {v.anim === 'anim-sql' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="10" y="24" width="36" height="20" rx="2" stroke-opacity="0.6"/>
                      <line x1="14" y1="32" x2="42" y2="32" stroke-opacity="0.4"/>
                      <line x1="14" y1="38" x2="34" y2="38" stroke-opacity="0.4"/>
                      <text class="quote" x="26" y="20" font-family="ui-monospace, monospace" font-size="20" fill="currentColor" stroke="none" font-weight="700">'</text>
                    </svg>
                  )}
                  {v.anim === 'anim-traverse' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M10 46 L20 46 L20 36 L46 36" stroke-opacity="0.5"/>
                      <path d="M10 36 L18 36 L18 28 L46 28" stroke-opacity="0.5"/>
                      <path d="M10 28 L18 28 L18 20 L46 20" stroke-opacity="0.5"/>
                      <g class="climb">
                        <circle cx="44" cy="42" r="2" fill="currentColor" stroke="none"/>
                        <circle cx="40" cy="42" r="2" fill="currentColor" stroke="none"/>
                      </g>
                    </svg>
                  )}
                  {v.anim === 'anim-noauth' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="14" y="28" width="28" height="20" rx="2"/>
                      <circle cx="28" cy="38" r="2.5" fill="currentColor" stroke="none"/>
                      <path class="shackle" d="M19 28 L19 20 a 9 9 0 0 1 14 -2" stroke-linecap="round"/>
                    </svg>
                  )}
                  {v.anim === 'anim-xss' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline class="l" points="20,18 12,28 20,38"/>
                      <polyline class="r" points="36,18 44,28 36,38"/>
                      <line x1="32" y1="14" x2="24" y2="42" stroke-opacity="0.5"/>
                    </svg>
                  )}
                  {v.anim === 'anim-ssrf' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="6" y="18" width="20" height="20" rx="2"/>
                      <circle cx="16" cy="28" r="3" fill="currentColor" stroke="none"/>
                      <circle cx="46" cy="28" r="3" stroke-opacity="0.6"/>
                      <g class="ray">
                        <line x1="28" y1="28" x2="42" y2="28" stroke-linecap="round"/>
                        <polyline points="38,24 42,28 38,32" stroke-linecap="round" stroke-linejoin="round"/>
                      </g>
                    </svg>
                  )}
                  {v.anim === 'anim-hardsecret' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="10" y1="18" x2="46" y2="18" stroke-opacity="0.4"/>
                      <line x1="10" y1="38" x2="46" y2="38" stroke-opacity="0.4"/>
                      <g class="key">
                        <circle cx="22" cy="28" r="5"/>
                        <line x1="27" y1="28" x2="42" y2="28" stroke-linecap="round"/>
                        <line x1="36" y1="28" x2="36" y2="32" stroke-linecap="round"/>
                        <line x1="40" y1="28" x2="40" y2="33" stroke-linecap="round"/>
                      </g>
                    </svg>
                  )}
                  {v.anim === 'anim-redirect' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <rect x="10" y="22" width="14" height="12" rx="1" stroke-opacity="0.5"/>
                      <path class="curve" d="M24 28 Q 36 28 36 40 Q 36 48 46 48" />
                      <polyline points="40,44 46,48 42,53" stroke-linejoin="round"/>
                    </svg>
                  )}
                  {v.anim === 'anim-logleak' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="12" y="10" width="32" height="34" rx="2" stroke-opacity="0.5"/>
                      <line x1="18" y1="20" x2="38" y2="20" stroke-opacity="0.4"/>
                      <line x1="18" y1="26" x2="34" y2="26" stroke-opacity="0.4"/>
                      <line x1="18" y1="32" x2="36" y2="32" stroke="currentColor"/>
                      <line x1="18" y1="38" x2="32" y2="38" stroke-opacity="0.4"/>
                      <ellipse class="leak" cx="38" cy="48" rx="2" ry="3" fill="currentColor" stroke="none"/>
                    </svg>
                  )}
                  {v.anim === 'anim-promptinj' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M10 14 L46 14 L46 36 L30 36 L22 44 L22 36 L10 36 Z"/>
                      <rect class="inner" x="20" y="20" width="20" height="10" rx="2" stroke="currentColor" stroke-opacity="0.8"/>
                    </svg>
                  )}
                  {v.anim === 'anim-defcred' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="10" y1="22" x2="46" y2="22" stroke-opacity="0.4"/>
                      <line x1="10" y1="34" x2="46" y2="34" stroke-opacity="0.4"/>
                      <text class="reveal" x="14" y="20" font-family="ui-monospace, monospace" font-size="9" fill="currentColor" stroke="none" font-weight="700">admin</text>
                      <text class="reveal" x="14" y="32" font-family="ui-monospace, monospace" font-size="9" fill="currentColor" stroke="none" font-weight="700">admin</text>
                    </svg>
                  )}
                  {v.anim === 'anim-cmdinj' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="14,18 22,28 14,38"/>
                      <line x1="26" y1="38" x2="34" y2="38"/>
                      <rect class="cursor" x="38" y="30" width="6" height="10" fill="currentColor" stroke="none"/>
                    </svg>
                  )}
                  {v.anim === 'anim-origin' && (
                    <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="6" y="18" width="16" height="20" rx="1"/>
                      <rect x="34" y="18" width="16" height="20" rx="1" stroke-opacity="0.5"/>
                      <path class="arc" d="M22 28 Q 28 18 34 28" stroke-linecap="round"/>
                      <polyline points="32,25 34,28 30,29" stroke-linecap="round" stroke-linejoin="round"/>
                      <text class="q" x="26" y="46" font-family="ui-monospace, monospace" font-size="12" fill="currentColor" stroke="none" font-weight="700">?</text>
                    </svg>
                  )}
                </div>
              </div>
              <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-1 shrink-0" style={sevPillStyle(v.severity)}>{v.severity}</span>
            </div>

            <h2 class="font-display tracking-tight leading-[1.05] text-mist-50" style="font-size: 1.4rem;">{v.title}</h2>
            <p class="text-mist-200 leading-[1.55] mt-3 text-[13.5px]">{v.description}</p>

            <div class="font-mono text-[10px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mt-5">Sample finding</div>
            <p class="text-mist-200 leading-[1.6] mt-2 text-[12.5px] pl-3 border-l-2 border-phosphor-500/60" set:html={v.sample.replace(/`([^`]+)`/g, '<code class="font-mono text-mist-50 bg-night-100 px-1.5 py-0.5 text-[11.5px]">$1</code>')}></p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CLOSER -->
  <section class="bg-night-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-3">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500">Forecast</div>
        </div>
        <div class="col-span-12 md:col-span-9">
          <p class="font-display italic text-mist-50 leading-[1.35]" style="font-size: clamp(1.5rem, 2.4vw, 2.25rem);">
            Prompt injection appears as a distinct category for the first time. Expect it to climb the ranking through 2026 as more code paths route through LLMs and the population of AI-backed endpoints grows.
          </p>
          <p class="text-mist-400 text-[12px] mt-6">
            Sample findings are paraphrased from real review comments. Identifying details are removed; the underlying pattern is preserved.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
