---
import Layout from '../layouts/Layout.astro';

const vulns = [
  { n: '01', title: 'SQL injection',                  severity: 'critical', note: 'Still the most common class in 2026.', sample: 'fmt.sprintf to directly embed user-controllable string variables into sql queries creating critical sql injection vulnerabilities' },
  { n: '02', title: 'Path traversal',                  severity: 'critical', note: 'Unsanitized URL parameters used to construct file paths.', sample: 'path traversal vulnerability in resolvepath. the function allows absolute paths (e.g. etc passwd) to be used directly completely bypassing the repository directory jail' },
  { n: '03', title: 'Missing authorization',           severity: 'critical', note: 'Endpoints without permission checks, or routers that lost auth during a refactor.', sample: 'the authorization dependencies have been removed from the api_keys clients and marketplace routers. previously these routers were protected by depends(require_scopes(...))' },
  { n: '04', title: 'XSS via unescaped attributes',    severity: 'high',     note: 'User-controlled values written into HTML attributes without escaping.', sample: 'html for the tooltips concatenando diretamente valores lidos de atributos data- em um atributo title sem qualquer tipo de sanitizacao' },
  { n: '05', title: 'SSRF',                            severity: 'high',     note: 'URL parameters fed into outbound HTTP requests, reaching internal services.', sample: 'the getmerchantid function is vulnerable to server-side request forgery (ssrf). it directly uses the link parameter which can be controlled by a user in an axios.get call without validation' },
  { n: '06', title: 'Hardcoded secrets in source',     severity: 'critical', note: 'Tokens, API keys, and credentials committed alongside code.', sample: 'hardcoding the cf-access-client-id and cf-access-client-secret directly into the source code is a critical security vulnerability. these credentials will be committed to the version control history permanently' },
  { n: '07', title: 'Open redirect',                   severity: 'medium',   note: 'Redirect helpers that block obvious schemes but miss protocol-relative URLs.', sample: 'the safe_return_to_path method is vulnerable to open redirection. it correctly blocks schemes like http and javascript but it allows protocol-relative urls such as evil.com' },
  { n: '08', title: 'Sensitive data in logs',          severity: 'high',     note: 'Raw error objects, internal IDs, or full payloads logged and never sanitized.', sample: 'the error message in banking.ts (lines 166-169) leaks internal workspaceid when a transaction is found but does not belong to the requesting store. this information leak allows verifying the existence of settlements' },
  { n: '09', title: 'Prompt injection',                severity: 'critical', isNew: true, note: 'System prompts that concatenate user-controlled strings without delimiters.', sample: 'el prompt del sistema concatena directamente datos potencialmente controlados por el usuario sin ningun tipo de delimitador o instruccion de saneamiento. esto crea una vulnerabilidad de inyeccion de prompt' },
  { n: '10', title: 'Default credentials',             severity: 'high',     note: 'Services deployed with well-known default usernames and passwords.', sample: 'the rabbitmq service is configured with the default well-known credentials guest guest. this is a significant security risk. the guest user is intended for local development' },
  { n: '11', title: 'Command injection',               severity: 'critical', note: 'User input passed unsanitized into shell commands.', sample: 'the basebranch parameter is used directly in a shell command without sanitization creating a command injection vulnerability. an attacker who can control the value can execute arbitrary commands' },
  { n: '12', title: 'PostMessage origin not validated', severity: 'high',    note: 'Window message listeners that process events from any origin.', sample: 'the message event listener is missing a crucial security check to validate the origin of the incoming event. without verifying event.origin the application will process messages sent from any website' },
];

const sevPillStyle = (sev: string) => {
  if (sev === 'critical') return 'background: var(--color-phosphor-500); color: var(--color-night-200);';
  if (sev === 'high')     return 'background: var(--color-phosphor-300); color: var(--color-night-200);';
  return 'background: oklch(35% 0.01 250); color: var(--color-mist-200);';
};
---

<Layout
  title="The 2026 vulnerability landscape · State of AI Code Review"
  description="The top security vulnerability classes AI code review caught on production pull requests in 2026. SQL injection still #1. Prompt injection enters the top 10."
  runningHead="§ 02 Vulnerabilities"
  page="Plate II"
  theme="dark"
>

  <!-- HERO -->
  <section class="border-b border-night-50 bg-night-100">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-16">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-9">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-5 reveal reveal-1">
            ◆ Chapter § 02 · Vulnerabilities
          </div>
          <h1 class="font-display leading-[0.95] tracking-tight text-mist-50 reveal reveal-2" style="font-size: clamp(2.5rem, 6.5vw, 5.5rem);">
            The 2026 vulnerability <span class="italic phosphor">landscape.</span>
          </h1>
        </div>
        <aside class="col-span-12 md:col-span-3 md:pt-4 reveal reveal-3">
          <div class="border border-night-50 bg-night-200 p-5">
            <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-4">At a glance</div>
            <ul class="space-y-3 text-mist-50">
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2">
                <span class="text-[13px] text-mist-200">Security findings</span>
                <span class="font-mono text-[13px]">6,552</span>
              </li>
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2">
                <span class="text-[13px] text-mist-200">Implemented or adapted</span>
                <span class="font-mono text-[13px] phosphor">28.8%</span>
              </li>
              <li class="flex items-baseline justify-between border-b border-night-50 pb-2">
                <span class="text-[13px] text-mist-200">Classes in top 10</span>
                <span class="font-mono text-[13px]">12</span>
              </li>
              <li class="flex items-baseline justify-between">
                <span class="text-[13px] text-mist-200">New in 2026</span>
                <span class="font-mono text-[13px] phosphor">1</span>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- PROMPT INJECTION HIGHLIGHT -->
  <section class="border-b border-night-50 bg-night-200 relative overflow-hidden">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20 relative">
      <div class="grid grid-cols-12 gap-10 items-center">
        <div class="col-span-12 md:col-span-7">
          <div class="flex items-center gap-3 mb-5">
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase px-2 py-1 pulse-mark" style="background: var(--color-night-300); color: var(--color-phosphor-500); border: 1px solid var(--color-phosphor-500);">new class · 2026</span>
            <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-1" style={sevPillStyle('critical')}>critical</span>
          </div>
          <h2 class="font-display tracking-tight leading-[0.95] text-mist-50" style="font-size: clamp(2.5rem, 6vw, 5rem);">
            <span class="italic phosphor">Prompt injection</span><br/>enters the top 10.
          </h2>
          <p class="text-mist-200 leading-[1.65] text-[16px] mt-6 max-w-xl">
            User-controlled strings concatenated into system prompts. Structurally similar to SQL injection from twenty years ago, freshly relevant as more production code paths route through LLMs. Expect this class to rise in subsequent snapshots.
          </p>
        </div>
        <div class="col-span-12 md:col-span-5">
          <div class="border border-phosphor-500/40 bg-night-300 p-6">
            <div class="font-mono text-[10px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mb-3">▌ excerpt · accepted finding</div>
            <p class="font-mono text-mist-200 leading-[1.7] text-[12.5px]">
              "el prompt del sistema concatena directamente datos potencialmente controlados por el usuario sin ningun tipo de delimitador o instruccion de saneamiento. esto crea una vulnerabilidad de inyeccion de prompt."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VULN GRID -->
  <section class="bg-night-100 border-b border-night-50">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-16">
      <div class="flex flex-wrap items-center gap-6 font-mono text-[11px] text-mist-400 mb-8">
        <span class="font-medium tracking-[0.22em] uppercase text-mist-200">Severity</span>
        <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" style={sevPillStyle('critical')}>critical</span>
        <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" style={sevPillStyle('high')}>high</span>
        <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-0.5" style={sevPillStyle('medium')}>medium</span>
        <span class="ml-auto text-mist-200">Sorted by frequency</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {vulns.map((v) => (
          <article class={`glow-on-hover border ${v.isNew ? 'border-phosphor-500/60' : 'border-night-50'} bg-night-200 p-6 relative`}>
            {v.isNew && (
              <div class="absolute -top-3 -right-3">
                <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-1 pulse-mark" style="background: var(--color-phosphor-500); color: var(--color-night-200);">NEW · 2026</span>
              </div>
            )}
            <div class="flex items-baseline justify-between">
              <span class="font-display italic phosphor leading-none" style="font-size: 2.25rem;">{v.n}</span>
              <span class="font-mono text-[10px] tracking-[0.18em] uppercase px-2 py-1" style={sevPillStyle(v.severity)}>{v.severity}</span>
            </div>
            <h2 class="font-display tracking-tight leading-[1.05] mt-4 text-mist-50" style="font-size: 1.4rem;">{v.title}</h2>
            <p class="text-mist-200 leading-[1.55] mt-3 text-[13.5px]">{v.note}</p>
            <div class="font-mono text-[10px] font-medium tracking-[0.22em] uppercase text-phosphor-500 mt-5">Excerpt</div>
            <blockquote class="font-mono text-[11.5px] leading-[1.65] text-mist-200 mt-2 pl-3 border-l-2 border-phosphor-500/60">
              {v.sample}
            </blockquote>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CLOSER -->
  <section class="bg-night-200">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-20">
      <div class="grid grid-cols-12 gap-8 items-start">
        <div class="col-span-12 md:col-span-3">
          <div class="font-mono text-[12px] font-medium tracking-[0.22em] uppercase text-phosphor-500">Forecast</div>
        </div>
        <div class="col-span-12 md:col-span-9">
          <p class="font-display italic text-mist-50 leading-[1.35]" style="font-size: clamp(1.5rem, 2.4vw, 2.25rem);">
            Prompt injection appears as a distinct category for the first time. Expect it to climb the ranking through 2026 as more code paths route through LLMs and as the population of AI-backed endpoints grows.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
